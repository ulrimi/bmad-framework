#!/bin/bash
# claude-feature - Launch Claude Code in an isolated git worktree
#
# REPO-AGNOSTIC: Auto-detects repo root from current directory.
# Works from any repo that has this script in its PATH.
#
# Usage:
#   claude-feature <feature-name>           Create/enter worktree (HITL mode)
#   claude-feature --ralph <name>           Create/enter worktree (Ralph autonomous mode)
#   claude-feature --yolo <name>            Create/enter worktree (HITL, skip permissions)
#   claude-feature --list                   List active worktrees
#   claude-feature --remove <name>          Remove a worktree
#   claude-feature --help                   Show this help

set -e

# === Auto-detect repo (NEVER hardcode paths) ===
MAIN_REPO=$(git rev-parse --show-toplevel 2>/dev/null)
if [ -z "$MAIN_REPO" ]; then
    echo "Error: Not in a git repository. Run from inside your project."
    exit 1
fi

PROJECT=$(basename "$MAIN_REPO")
BASE_DIR=$(dirname "$MAIN_REPO")

# Robust default branch detection
DEFAULT_BRANCH=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@')
if [ -z "$DEFAULT_BRANCH" ]; then
    git remote set-head origin --auto 2>/dev/null || true
    DEFAULT_BRANCH=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@')
fi
DEFAULT_BRANCH="${DEFAULT_BRANCH:-main}"

# Mode: "feature" (HITL) or "ralph" (autonomous)
MODE="feature"
SKIP_PERMISSIONS=false

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
NC='\033[0m'

print_help() {
    cat << EOF
claude-feature - Launch Claude Code in an isolated git worktree

REPO: $MAIN_REPO ($PROJECT)
DEFAULT BRANCH: $DEFAULT_BRANCH

USAGE:
    claude-feature <name>              HITL worktree (feature/<name> branch)
    claude-feature --yolo <name>       HITL worktree (skip permissions)
    claude-feature --ralph <name>      Ralph worktree (ralph/<name> branch, auto-skip permissions)
    claude-feature --list              List all active worktrees
    claude-feature --remove <name>     Remove a specific worktree
    claude-feature --clean             Remove all non-main worktrees
    claude-feature --help              Show this help

HITL MODE (default):
    claude-feature frontend
      -> Creates ${PROJECT}-frontend/ on feature/frontend branch
      -> Launches Claude Code (interactive, permission prompts)
      -> Tip: /implement frontend

YOLO MODE:
    claude-feature --yolo frontend
      -> Same as HITL but skips permission prompts

RALPH MODE (--ralph):
    claude-feature --ralph exception-hardening
      -> Creates ${PROJECT}-ralph-exception-hardening/ on ralph/exception-hardening branch
      -> Launches Claude Code with --dangerously-skip-permissions
      -> Paste /ralph-loop prompt and walk away

PARALLEL LOOPS:
    Terminal 1: claude-feature --ralph exception-hardening
    Terminal 2: claude-feature --ralph security-config
    Terminal 3: claude-feature frontend

NOTES:
    - Worktrees share .git with the main repo (fast, disk-efficient)
    - Changes in one worktree don't affect others
    - Each worktree has its own branch
    - After completion: review, push, PR, merge as normal
    - Ralph branches use ralph/ prefix to distinguish from HITL feature/ branches
EOF
}

list_worktrees() {
    echo -e "${BLUE}Active worktrees for ${PROJECT}:${NC}"
    echo ""
    cd "$MAIN_REPO"

    git worktree list | while read -r line; do
        worktree_path=$(echo "$line" | awk '{print $1}')
        branch=$(echo "$line" | awk '{print $3}' | tr -d '[]')

        if [[ "$worktree_path" == "$MAIN_REPO" ]]; then
            echo -e "  ${GREEN}$worktree_path${NC} (main repo) [$branch]"
        elif [[ "$branch" == ralph/* ]]; then
            local name="${branch#ralph/}"
            echo -e "  ${MAGENTA}$worktree_path${NC}"
            echo -e "    Branch: $branch"
            echo -e "    Mode: Ralph (autonomous)"

            if [ -d "$worktree_path" ]; then
                local last_commit
                last_commit=$(git -C "$worktree_path" log --oneline -1 2>/dev/null || echo "no commits yet")
                echo -e "    Last commit: $last_commit"
                if [ -f "$worktree_path/RALPH_LOG.md" ]; then
                    echo -e "    ${YELLOW}Has RALPH_LOG.md (check for blockers)${NC}"
                fi
            fi

            echo -e "    Resume: claude-feature --ralph $name"
        else
            local name
            name=$(basename "$worktree_path" | sed "s/${PROJECT}-//")
            echo -e "  ${YELLOW}$worktree_path${NC}"
            echo -e "    Branch: $branch"
            echo -e "    Mode: HITL (interactive)"
            echo -e "    Resume: claude-feature $name"
        fi
        echo ""
    done
}

remove_worktree() {
    local name=$1
    local worktree="$BASE_DIR/${PROJECT}-ralph-${name}"
    local branch="ralph/${name}"

    if [ ! -d "$worktree" ]; then
        worktree="$BASE_DIR/${PROJECT}-${name}"
        branch="feature/${name}"
    fi

    if [ ! -d "$worktree" ]; then
        echo -e "${RED}Error: Worktree not found for '${name}'${NC}"
        echo "Tried: $BASE_DIR/${PROJECT}-ralph-${name}"
        echo "  and: $BASE_DIR/${PROJECT}-${name}"
        exit 1
    fi

    echo -e "${YELLOW}Removing worktree: $worktree${NC}"
    echo -e "  Branch: $branch"

    cd "$worktree"
    if ! git diff --quiet 2>/dev/null || ! git diff --cached --quiet 2>/dev/null; then
        echo -e "${RED}Warning: Uncommitted changes in worktree!${NC}"
        read -p "Remove anyway? (y/N) " confirm
        if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
            echo "Aborted."
            exit 1
        fi
    fi

    local unpushed
    unpushed=$(git -C "$worktree" log --oneline "origin/$DEFAULT_BRANCH..$branch" 2>/dev/null | wc -l | tr -d ' ')
    if [ "$unpushed" -gt 0 ]; then
        echo -e "${YELLOW}Warning: $unpushed unpushed commit(s) on $branch${NC}"
        git -C "$worktree" log --oneline "origin/$DEFAULT_BRANCH..$branch" 2>/dev/null | head -5
        read -p "Remove anyway? (y/N) " confirm
        if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
            echo "Aborted."
            exit 1
        fi
    fi

    cd "$MAIN_REPO"
    git worktree remove "$worktree" --force

    read -p "Also delete branch ${branch}? (y/N) " delete_branch
    if [[ "$delete_branch" =~ ^[Yy]$ ]]; then
        git branch -D "$branch" 2>/dev/null || true
    fi

    echo -e "${GREEN}Worktree removed.${NC}"
}

clean_all_worktrees() {
    echo -e "${YELLOW}This will remove ALL feature and ralph worktrees for ${PROJECT}.${NC}"
    read -p "Are you sure? (y/N) " confirm
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        echo "Aborted."
        exit 1
    fi

    cd "$MAIN_REPO"
    git worktree list | while read -r line; do
        worktree_path=$(echo "$line" | awk '{print $1}')
        if [[ "$worktree_path" != "$MAIN_REPO" ]]; then
            echo "Removing: $worktree_path"
            git worktree remove "$worktree_path" --force 2>/dev/null || true
        fi
    done

    echo -e "${GREEN}All worktrees removed.${NC}"
}

create_and_enter_worktree() {
    local name=$1
    local worktree branch claude_args tip_text header_text

    if [ "$MODE" = "ralph" ]; then
        worktree="$BASE_DIR/${PROJECT}-ralph-${name}"
        branch="ralph/${name}"
        claude_args="--dangerously-skip-permissions"
        tip_text="Paste your /ralph-loop prompt to begin autonomous execution"
        header_text="Ralph Autonomous Workspace"
    else
        worktree="$BASE_DIR/${PROJECT}-${name}"
        branch="feature/${name}"
        if [ "$SKIP_PERMISSIONS" = "true" ]; then
            claude_args="--dangerously-skip-permissions"
            tip_text="Run '/implement ${name}' to start (--yolo: permissions skipped)"
            header_text="Claude Feature Workspace (Yolo Mode)"
        else
            claude_args=""
            tip_text="Run '/implement ${name}' to start implementing the epic"
            header_text="Claude Feature Workspace"
        fi
    fi

    echo -e "${BLUE}=== $header_text ===${NC}"
    echo ""

    cd "$MAIN_REPO"

    if [ -d "$worktree" ]; then
        echo -e "${GREEN}Worktree exists: $worktree${NC}"
        echo "Entering existing worktree..."
    else
        echo -e "${YELLOW}Creating new worktree...${NC}"
        echo "  Path: $worktree"
        echo "  Branch: $branch"
        echo "  Mode: $([ "$MODE" = "ralph" ] && echo "Ralph (autonomous)" || echo "HITL (interactive)")"
        echo ""

        git fetch origin "$DEFAULT_BRANCH" 2>/dev/null || true

        if git show-ref --verify --quiet "refs/heads/$branch"; then
            git worktree add "$worktree" "$branch"
        else
            git worktree add -b "$branch" "$worktree" "$DEFAULT_BRANCH"
        fi

        echo -e "${GREEN}Worktree created.${NC}"
    fi

    # Symlink .claude config (only if not already in the worktree via git)
    if [ ! -d "$worktree/.claude" ] && [ ! -L "$worktree/.claude" ]; then
        echo "Symlinking .claude/ config..."
        ln -s "$MAIN_REPO/.claude" "$worktree/.claude"
    fi

    # Symlink CLAUDE.md (only if not already in the worktree via git)
    if [ ! -f "$worktree/CLAUDE.md" ] && [ ! -L "$worktree/CLAUDE.md" ]; then
        echo "Symlinking CLAUDE.md..."
        ln -s "$MAIN_REPO/CLAUDE.md" "$worktree/CLAUDE.md"
    fi

    # Symlink bmad/ only for HITL mode (Ralph doesn't use BMAD workflow)
    if [ "$MODE" = "feature" ]; then
        if [ ! -d "$worktree/bmad" ] && [ ! -L "$worktree/bmad" ]; then
            echo "Symlinking bmad/..."
            ln -s "$MAIN_REPO/bmad" "$worktree/bmad"
        fi
    fi

    # Symlink venv (so pytest/ruff work)
    if [ ! -d "$worktree/venv" ] && [ ! -L "$worktree/venv" ]; then
        if [ -d "$MAIN_REPO/venv" ]; then
            echo "Symlinking venv/..."
            ln -s "$MAIN_REPO/venv" "$worktree/venv"
        fi
    fi

    echo ""
    if [ "$MODE" = "ralph" ]; then
        echo -e "${MAGENTA}=== Starting Claude (Ralph Mode) ===${NC}"
        echo -e "  Permissions: ${YELLOW}SKIPPED (autonomous mode)${NC}"
    elif [ "$SKIP_PERMISSIONS" = "true" ]; then
        echo -e "${YELLOW}=== Starting Claude (Yolo Mode) ===${NC}"
        echo -e "  Permissions: ${YELLOW}SKIPPED (--yolo)${NC}"
    else
        echo -e "${GREEN}=== Starting Claude ===${NC}"
        echo -e "  Permissions: interactive (use --yolo to skip)"
    fi
    echo "  Working directory: $worktree"
    echo "  Branch: $branch"
    echo ""
    echo -e "${YELLOW}Tip: ${tip_text}${NC}"
    echo ""

    cd "$worktree"

    export CLAUDE_FEATURE="$name"
    export CLAUDE_WORKTREE="$worktree"
    export CLAUDE_MODE="$MODE"

    # shellcheck disable=SC2086
    exec claude $claude_args
}

# Parse arguments
POSITIONAL_ARGS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --help|-h)
            print_help
            exit 0
            ;;
        --list|-l)
            list_worktrees
            exit 0
            ;;
        --remove|-r)
            if [ -z "${2:-}" ]; then
                echo -e "${RED}Error: --remove requires a name${NC}"
                exit 1
            fi
            remove_worktree "$2"
            exit 0
            ;;
        --clean)
            clean_all_worktrees
            exit 0
            ;;
        --ralph)
            MODE="ralph"
            SKIP_PERMISSIONS=true
            shift
            ;;
        --yolo)
            SKIP_PERMISSIONS=true
            shift
            ;;
        -*)
            echo -e "${RED}Error: Unknown option: $1${NC}"
            print_help
            exit 1
            ;;
        *)
            POSITIONAL_ARGS+=("$1")
            shift
            ;;
    esac
done

# Restore positional args
set -- "${POSITIONAL_ARGS[@]}"

if [ -z "${1:-}" ]; then
    echo -e "${RED}Error: Name required${NC}"
    echo ""
    print_help
    exit 1
fi

create_and_enter_worktree "$1"
