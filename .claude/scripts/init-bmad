#!/usr/bin/env bash
# init-bmad — Bootstrap BMAD story-driven development framework in a new project
# Usage: init-bmad [--name "Project Name"] [--stack python|typescript|go|other]
#                  [--specialists "backend,data,qa"] [--non-interactive]
#                  [--upgrade] [--dry-run]
# Source: ~/.claude/scripts/init-bmad

set -euo pipefail

TEMPLATE_DIR="${HOME}/.claude/bmad-template"
SCRIPT_NAME="init-bmad"

# ─── Colors ───────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# ─── Helpers ──────────────────────────────────────────────────────────────────
info()    { echo -e "${BLUE}[init-bmad]${NC} $*"; }
success() { echo -e "${GREEN}[init-bmad]${NC} $*"; }
warn()    { echo -e "${YELLOW}[init-bmad]${NC} $*"; }
error()   { echo -e "${RED}[init-bmad] ERROR:${NC} $*" >&2; exit 1; }
prompt()  { echo -e "${CYAN}${BOLD}?${NC} $*"; }

# Scaffold lints/ directory with stack-appropriate starter scripts.
# Usage: _scaffold_lints <stack>  (e.g., python, typescript)
_scaffold_lints() {
  local _stack="${1:-python}"
  mkdir -p lints

  if [[ -f "${TEMPLATE_DIR}/lints/README.md" ]]; then
    cp "${TEMPLATE_DIR}/lints/README.md" lints/README.md
  fi

  case "${_stack}" in
    python)
      [[ -d "${TEMPLATE_DIR}/lints/python" ]] && cp "${TEMPLATE_DIR}/lints/python/"*.py lints/ 2>/dev/null || true
      ;;
    typescript|javascript)
      [[ -d "${TEMPLATE_DIR}/lints/typescript" ]] && cp "${TEMPLATE_DIR}/lints/typescript/"*.js lints/ 2>/dev/null || true
      ;;
    *)
      [[ -d "${TEMPLATE_DIR}/lints/python" ]] && cp "${TEMPLATE_DIR}/lints/python/"*.py lints/ 2>/dev/null || true
      ;;
  esac

  chmod +x lints/*.py lints/*.js 2>/dev/null || true
}

# ─── Pre-flight ───────────────────────────────────────────────────────────────
if [[ ! -d "${TEMPLATE_DIR}" ]]; then
  error "Template directory not found: ${TEMPLATE_DIR}\nRun: ls ~/.claude/bmad-template to verify install."
fi

if ! git rev-parse --git-dir > /dev/null 2>&1; then
  error "Not inside a git repository. Run 'git init' first or cd into an existing repo."
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
if [[ "$(pwd)" != "${REPO_ROOT}" ]]; then
  warn "You are not in the repo root. Running from: ${REPO_ROOT}"
  cd "${REPO_ROOT}" || error "Cannot cd to repo root"
fi

# ─── Argument parsing ─────────────────────────────────────────────────────────
PROJECT_NAME=""
PRIMARY_STACK=""
SPECIALISTS_RAW=""
NON_INTERACTIVE=false
DESCRIPTION=""
ARCH_PATTERN=""
BACKEND_FRAMEWORK=""
FRONTEND_FRAMEWORK=""
DATA_TOOLS=""
DATABASE=""
GITIGNORE_BMAD=""
FULL_SCAFFOLD=false
UPGRADE_MODE=false
DRY_RUN=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --name)               PROJECT_NAME="$2"; shift 2 ;;
    --stack)              PRIMARY_STACK="$2"; shift 2 ;;
    --specialists)        SPECIALISTS_RAW="$2"; shift 2 ;;
    --desc)               DESCRIPTION="$2"; shift 2 ;;
    --arch)               ARCH_PATTERN="$2"; shift 2 ;;
    --backend-framework)  BACKEND_FRAMEWORK="$2"; shift 2 ;;
    --frontend-framework) FRONTEND_FRAMEWORK="$2"; shift 2 ;;
    --data-tools)         DATA_TOOLS="$2"; shift 2 ;;
    --database)           DATABASE="$2"; shift 2 ;;
    --gitignore)          GITIGNORE_BMAD="yes"; shift ;;
    --no-gitignore)       GITIGNORE_BMAD="no"; shift ;;
    --full)               FULL_SCAFFOLD=true; shift ;;
    --upgrade)            UPGRADE_MODE=true; shift ;;
    --dry-run)            DRY_RUN=true; shift ;;
    --non-interactive)    NON_INTERACTIVE=true; shift ;;
    -h|--help)
      echo "Usage: ${SCRIPT_NAME} [options]"
      echo ""
      echo "Options:"
      echo "  --name NAME                 Project name (default: directory name)"
      echo "  --stack STACK               Primary language: python|typescript|go|other"
      echo "  --specialists LIST          Comma-separated: backend,frontend,data,qa,infra"
      echo "  --desc DESCRIPTION          One-line project description"
      echo "  --arch PATTERN              Architecture: monolith|monorepo|microservices|serverless|library"
      echo "  --backend-framework NAME    Backend framework (e.g., fastapi, express, gin)"
      echo "  --frontend-framework NAME   Frontend framework (e.g., react, vue, svelte)"
      echo "  --data-tools TOOLS          Data tools (e.g., pandas, sqlalchemy, spark)"
      echo "  --database DB               Database: postgres|mysql|sqlite|mongodb|none"
      echo "  --full                      Scaffold full docs/ knowledge base (design-docs, exec-plans, etc.)"
      echo "  --upgrade                   Non-destructive upgrade: detect and add missing harness artifacts"
      echo "  --dry-run                   Show what --upgrade would do, without making changes"
      echo "  --gitignore                 Add BMAD files to .gitignore (for existing/corporate repos)"
      echo "  --no-gitignore              Commit BMAD files to repo (for new projects, default)"
      echo "  --non-interactive           Use defaults, no prompts"
      exit 0
      ;;
    *) warn "Unknown option: $1"; shift ;;
  esac
done

# ─── Existing-project guard (skipped in upgrade mode) ────────────────────────
if [[ -d "bmad/config" ]] && [[ "${UPGRADE_MODE}" == false ]]; then
  warn "bmad/config already exists. Re-running will overwrite workflow/task/template files but preserve epics and agent customizations."
  read -r -p "Continue? [y/N] " confirm
  [[ "${confirm}" =~ ^[Yy]$ ]] || { info "Aborted."; exit 0; }
fi

# ─── Upgrade mode ────────────────────────────────────────────────────────────
if [[ "${UPGRADE_MODE}" == true ]]; then
  # Pre-flight: require existing BMAD setup
  if [[ ! -f "bmad/config/core-config.yaml" ]]; then
    error "No existing BMAD setup detected. Use 'init-bmad' (without --upgrade) to bootstrap a new project."
  fi

  # Extract project info from existing config
  PROJECT_NAME=$(grep -E '^\s+name:' bmad/config/core-config.yaml | head -1 | sed 's/.*name: *"\{0,1\}\([^"]*\)"\{0,1\}/\1/')
  PROJECT_NAME="${PROJECT_NAME:-$(basename "${REPO_ROOT}")}"
  DESCRIPTION=$(grep -E '^\s+description:' bmad/config/core-config.yaml | head -1 | sed 's/.*description: *"\{0,1\}\([^"]*\)"\{0,1\}/\1/')
  DESCRIPTION="${DESCRIPTION:-${PROJECT_NAME}}"

  info "Scanning existing BMAD setup for ${PROJECT_NAME}..."

  # ─── Detection phase ──────────────────────────────────────────────────
  EXISTING=()
  MISSING=()
  MISSING_IDS=()

  # Track what exists
  if [[ -f "CLAUDE.md" ]]; then
    _lines=$(wc -l < CLAUDE.md | tr -d ' ')
    EXISTING+=("CLAUDE.md (${_lines} lines)")
  fi
  [[ -f "bmad/config/core-config.yaml" ]] && EXISTING+=("core-config.yaml")

  _agent_count=$(find bmad/config/agents/active -name '*.md' 2>/dev/null | wc -l | tr -d ' ')
  [[ "${_agent_count}" -gt 0 ]] && EXISTING+=("${_agent_count} specialist agents")

  [[ -d "bmad/config/workflows" ]] && EXISTING+=("Workflows")
  [[ -d "bmad/config/tasks" ]] && EXISTING+=("Tasks")
  [[ -d "bmad/config/templates" ]] && EXISTING+=("Templates")
  [[ -d "bmad/config/checklists" ]] && EXISTING+=("Checklists")

  # ─── Check each harness engineering artifact ───────────────────────────

  # 1. ARCHITECTURE.md
  if [[ ! -f "ARCHITECTURE.md" ]]; then
    MISSING+=("ARCHITECTURE.md — System map with codemap, invariants, boundaries")
    MISSING_IDS+=("architecture")
  fi

  # 2. golden-principles.md
  if [[ ! -f "bmad/config/golden-principles.md" ]]; then
    MISSING+=("golden-principles.md — Code taste rules for this project")
    MISSING_IDS+=("golden-principles")
  fi

  # 3. Knowledge Map in CLAUDE.md
  if [[ -f "CLAUDE.md" ]] && ! grep -q "## Knowledge Map" CLAUDE.md; then
    MISSING+=("Knowledge Map in CLAUDE.md — Pointers to deeper docs")
    MISSING_IDS+=("knowledge-map")
  fi

  # 4. docs/ directory structure
  _docs_complete=true
  for _d in docs/design-docs docs/exec-plans docs/product-specs docs/references docs/generated; do
    [[ -d "${_d}" ]] || _docs_complete=false
  done
  if [[ "${_docs_complete}" == false ]]; then
    MISSING+=("docs/ knowledge structure — Design docs, exec-plans, references")
    MISSING_IDS+=("docs-scaffold")
  fi

  # 5. core-beliefs.md
  if [[ ! -f "docs/design-docs/core-beliefs.md" ]]; then
    _suffix=""
    [[ ! -d "docs" ]] && _suffix=" (requires docs/)"
    MISSING+=("core-beliefs.md — Agent-first operating principles${_suffix}")
    MISSING_IDS+=("core-beliefs")
  fi

  # 6. QUALITY_SCORE.md
  if [[ ! -f "docs/QUALITY_SCORE.md" ]]; then
    _suffix=""
    [[ ! -d "docs" ]] && _suffix=" (requires docs/)"
    MISSING+=("QUALITY_SCORE.md — Quality scoring template${_suffix}")
    MISSING_IDS+=("quality-score")
  fi

  # 7. structural_validation in core-config.yaml
  if ! grep -q "structural_validation:" bmad/config/core-config.yaml; then
    MISSING+=("structural_validation in core-config.yaml — Mechanical enforcement hooks")
    MISSING_IDS+=("structural-validation")
  fi

  # 8. tech-debt-tracker.md
  if [[ ! -f "docs/exec-plans/tech-debt-tracker.md" ]]; then
    _suffix=""
    [[ ! -d "docs" ]] && _suffix=" (requires docs/)"
    MISSING+=("tech-debt-tracker.md — Tech debt tracking${_suffix}")
    MISSING_IDS+=("tech-debt-tracker")
  fi

  # 9. lints/ directory
  if [[ ! -d "lints" ]]; then
    MISSING+=("lints/ — Custom structural validation scripts with agent-friendly error messages")
    MISSING_IDS+=("lints-scaffold")
  fi

  # 10. Living-document sections in epic template
  if [[ -f "bmad/config/templates/epic-template.md" ]]; then
    _missing_sections=0
    grep -q "## Progress" bmad/config/templates/epic-template.md || _missing_sections=$((_missing_sections + 1))
    grep -q "## Surprises" bmad/config/templates/epic-template.md || _missing_sections=$((_missing_sections + 1))
    grep -q "## Decision Log" bmad/config/templates/epic-template.md || _missing_sections=$((_missing_sections + 1))
    grep -q "## Outcomes" bmad/config/templates/epic-template.md || _missing_sections=$((_missing_sections + 1))
    if [[ ${_missing_sections} -gt 0 ]]; then
      MISSING+=("Living-document sections in epic template — Progress, Surprises, Decision Log, Retrospective")
      MISSING_IDS+=("living-docs")
    fi
  fi

  # ─── Display report ────────────────────────────────────────────────────
  echo ""
  echo -e "${CYAN}${BOLD}╔══════════════════════════════════════════╗${NC}"
  echo -e "${CYAN}${BOLD}║       BMAD Upgrade — Gap Analysis        ║${NC}"
  echo -e "${CYAN}${BOLD}╚══════════════════════════════════════════╝${NC}"
  echo ""

  echo -e "${BOLD}Existing setup detected:${NC}"
  for item in ${EXISTING[@]+"${EXISTING[@]}"}; do
    echo -e "  ${GREEN}✓${NC} ${item}"
  done
  echo ""

  if [[ ${#MISSING[@]} -eq 0 ]]; then
    success "All harness engineering artifacts are present. Nothing to upgrade!"
    exit 0
  fi

  echo -e "${BOLD}Missing harness engineering artifacts:${NC}"
  for i in "${!MISSING[@]}"; do
    echo -e "  ${YELLOW}[$((i + 1))]${NC} ${MISSING[$i]}"
  done
  echo ""

  # ─── Dry-run display helper ──────────────────────────────────────────
  _show_dry_run() {
    echo -e "${BOLD}Dry run — no changes will be made.${NC}"
    echo ""
    echo "Would create/modify:"
    for i in "${!MISSING_IDS[@]}"; do
      case "${MISSING_IDS[$i]}" in
        architecture)           echo "  CREATE  ARCHITECTURE.md" ;;
        golden-principles)      echo "  CREATE  bmad/config/golden-principles.md" ;;
        knowledge-map)          echo "  MODIFY  CLAUDE.md (insert ## Knowledge Map section)" ;;
        docs-scaffold)          echo "  CREATE  docs/ directory structure" ;;
        core-beliefs)           echo "  CREATE  docs/design-docs/core-beliefs.md" ;;
        quality-score)          echo "  CREATE  docs/QUALITY_SCORE.md" ;;
        structural-validation)  echo "  MODIFY  bmad/config/core-config.yaml (append structural_validation)" ;;
        tech-debt-tracker)      echo "  CREATE  docs/exec-plans/tech-debt-tracker.md" ;;
        lints-scaffold)         echo "  CREATE  lints/ directory with starter validation scripts" ;;
        living-docs)            echo "  MODIFY  bmad/config/templates/epic-template.md (append sections)" ;;
      esac
    done
    echo ""
    info "Run 'init-bmad --upgrade' (without --dry-run) to apply changes."
  }

  # ─── If --dry-run, show and exit ───────────────────────────────────────
  if [[ "${DRY_RUN}" == true ]]; then
    _show_dry_run
    exit 0
  fi

  # ─── Interactive selection ─────────────────────────────────────────────
  SELECTED_IDS=()

  if [[ "${NON_INTERACTIVE}" == true ]]; then
    SELECTED_IDS=("${MISSING_IDS[@]}")
  else
    echo -e "${BOLD}Options:${NC}"
    echo "  a) Apply all    s) Select individually    d) Dry-run    q) Quit"
    echo ""
    prompt "Choice? [a]"
    read -r choice

    case "${choice}" in
      q|Q) info "Aborted."; exit 0 ;;
      d|D) _show_dry_run; exit 0 ;;
      s|S)
        echo ""
        for i in "${!MISSING[@]}"; do
          prompt "Add [$((i + 1))] ${MISSING[$i]}? [Y/n]"
          read -r yn
          if [[ ! "${yn}" =~ ^[Nn]$ ]]; then
            SELECTED_IDS+=("${MISSING_IDS[$i]}")
          fi
        done
        ;;
      *)
        SELECTED_IDS=("${MISSING_IDS[@]}")
        ;;
    esac
  fi

  if [[ ${#SELECTED_IDS[@]} -eq 0 ]]; then
    info "No artifacts selected. Nothing to do."
    exit 0
  fi

  # ─── Apply upgrades ───────────────────────────────────────────────────
  CREATED_FILES=()
  CREATED_DESCS=()
  MODIFIED_DESCS=()

  # Helper: create backup without overwriting previous backups
  _safe_backup() {
    local _src="$1"
    local _bak="${_src}.upgrade-backup"
    if [[ -f "${_bak}" ]]; then
      _bak="${_src}.upgrade-backup.$(date +%Y%m%d%H%M%S)"
      warn "Existing backup found, saving to ${_bak}"
    fi
    cp "${_src}" "${_bak}"
    echo "${_bak}"
  }

  # Helper: check if ID is in selected list
  _selected() {
    local _id="$1"
    for _s in ${SELECTED_IDS[@]+"${SELECTED_IDS[@]}"}; do
      [[ "${_s}" == "${_id}" ]] && return 0
    done
    return 1
  }

  # Handle docs/ dependency for docs-layer artifacts (AC7)
  _needs_docs=false
  for _dep_id in core-beliefs quality-score tech-debt-tracker; do
    if _selected "${_dep_id}" && [[ ! -d "docs" ]]; then
      _needs_docs=true
      break
    fi
  done

  if [[ "${_needs_docs}" == true ]] && ! _selected "docs-scaffold"; then
    warn "Selected artifacts require docs/ directory structure."
    if [[ "${NON_INTERACTIVE}" == true ]]; then
      SELECTED_IDS+=("docs-scaffold")
    else
      prompt "Create docs/ structure first? [Y/n]"
      read -r yn
      if [[ ! "${yn}" =~ ^[Nn]$ ]]; then
        SELECTED_IDS+=("docs-scaffold")
      else
        warn "Skipping docs-dependent artifacts (core-beliefs, QUALITY_SCORE, tech-debt-tracker)."
      fi
    fi
  fi

  # ── Apply: docs scaffold (must run first — others depend on it) ──────
  if _selected "docs-scaffold"; then
    info "Creating docs/ knowledge structure..."
    mkdir -p docs/design-docs docs/exec-plans/active docs/exec-plans/completed \
             docs/product-specs docs/references docs/generated

    for _tpl in docs/design-docs/index.md docs/product-specs/index.md docs/references/README.md; do
      if [[ -f "${TEMPLATE_DIR}/${_tpl}" ]] && [[ ! -f "${_tpl}" ]]; then
        cp "${TEMPLATE_DIR}/${_tpl}" "${_tpl}"
        sed -i.bak -e "s|{{PROJECT_NAME}}|${PROJECT_NAME}|g" "${_tpl}" && rm "${_tpl}.bak"
        CREATED_FILES+=("${_tpl}")
      fi
    done

    [[ -f "docs/generated/.gitkeep" ]] || touch docs/generated/.gitkeep
    CREATED_DESCS+=("docs/ directory structure (design-docs, exec-plans, product-specs, references, generated)")
    success "docs/ directory structure created."
  fi

  # ── Apply: ARCHITECTURE.md ──────────────────────────────────────────
  if _selected "architecture"; then
    if [[ -f "${TEMPLATE_DIR}/templates/architecture-template.md" ]]; then
      info "Creating ARCHITECTURE.md..."
      cp "${TEMPLATE_DIR}/templates/architecture-template.md" ARCHITECTURE.md
      sed -i.bak \
        -e "s|{{PROJECT_NAME}}|${PROJECT_NAME}|g" \
        -e "s|{{PROJECT_DESCRIPTION}}|${DESCRIPTION}|g" \
        ARCHITECTURE.md && rm ARCHITECTURE.md.bak
      CREATED_FILES+=("ARCHITECTURE.md")
      CREATED_DESCS+=("ARCHITECTURE.md")
      success "ARCHITECTURE.md created."
    else
      warn "architecture-template.md not found in templates — skipping."
    fi
  fi

  # ── Apply: golden-principles.md ─────────────────────────────────────
  if _selected "golden-principles"; then
    if [[ -f "${TEMPLATE_DIR}/templates/golden-principles.md" ]]; then
      info "Creating golden-principles.md..."
      cp "${TEMPLATE_DIR}/templates/golden-principles.md" bmad/config/golden-principles.md
      sed -i.bak -e "s|{{PROJECT_NAME}}|${PROJECT_NAME}|g" \
        bmad/config/golden-principles.md && rm bmad/config/golden-principles.md.bak
      CREATED_FILES+=("bmad/config/golden-principles.md")
      CREATED_DESCS+=("bmad/config/golden-principles.md")
      success "golden-principles.md created."
    else
      warn "golden-principles.md template not found — skipping."
    fi
  fi

  # ── Apply: Knowledge Map in CLAUDE.md (AC5) ─────────────────────────
  if _selected "knowledge-map"; then
    if [[ -f "CLAUDE.md" ]]; then
      info "Inserting Knowledge Map into CLAUDE.md..."
      _claude_backup=$(_safe_backup CLAUDE.md)

      # Build Knowledge Map dynamically based on what actually exists
      _km_lines=()
      _km_lines+=("## Knowledge Map")
      _km_lines+=("")
      _km_lines+=("| Doc | Path | Purpose |")
      _km_lines+=("|-----|------|---------|")
      [[ -f "ARCHITECTURE.md" ]] && \
        _km_lines+=("| Architecture | \`ARCHITECTURE.md\` | Codemap, invariants, boundaries |")
      [[ -f "bmad/config/golden-principles.md" ]] && \
        _km_lines+=("| Golden Principles | \`bmad/config/golden-principles.md\` | Style rules and taste invariants |")
      [[ -f "bmad/config/core-config.yaml" ]] && \
        _km_lines+=("| Core Config | \`bmad/config/core-config.yaml\` | Project settings and specialist list |")
      [[ -d "bmad/config/workflows" ]] && \
        _km_lines+=("| BMAD Workflow | \`bmad/config/workflows/bmad-flow.md\` | Orchestration phases |")
      [[ -d "bmad/config/agents/active" ]] && \
        _km_lines+=("| Specialist Agents | \`bmad/config/agents/active/\` | Domain-specific agent personas |")
      [[ -d "bmad/epics" ]] && \
        _km_lines+=("| Epics & Stories | \`bmad/epics/\` | All epics and their stories |")
      [[ -d "docs/design-docs" ]] && \
        _km_lines+=("| Design Docs | \`docs/design-docs/\` | Technical design documents |")
      [[ -f "docs/design-docs/core-beliefs.md" ]] && \
        _km_lines+=("| Core Beliefs | \`docs/design-docs/core-beliefs.md\` | Agent-first operating principles |")
      [[ -d "docs/exec-plans" ]] && \
        _km_lines+=("| Exec Plans | \`docs/exec-plans/\` | Execution plans for complex work |")
      [[ -d "docs/product-specs" ]] && \
        _km_lines+=("| Product Specs | \`docs/product-specs/\` | Product specifications |")
      [[ -d "docs/references" ]] && \
        _km_lines+=("| References | \`docs/references/\` | LLM-friendly dependency docs |")
      [[ -f "docs/QUALITY_SCORE.md" ]] && \
        _km_lines+=("| Quality Score | \`docs/QUALITY_SCORE.md\` | Quality scoring template |")

      # Write Knowledge Map to temp file
      _km_tmp=$(mktemp)
      printf '%s\n' "${_km_lines[@]}" > "${_km_tmp}"

      # Insert before the first ## heading using Python for reliability
      python3 -c "
import sys
km = open(sys.argv[1]).read()
content = open('CLAUDE.md').read()
lines = content.split('\n')
insert_idx = len(lines)
for i, line in enumerate(lines):
    if line.startswith('## '):
        insert_idx = i
        break
lines.insert(insert_idx, '')
lines.insert(insert_idx, km.rstrip())
lines.insert(insert_idx, '')
open('CLAUDE.md', 'w').write('\n'.join(lines))
" "${_km_tmp}"

      rm -f "${_km_tmp}"
      MODIFIED_DESCS+=("CLAUDE.md (Knowledge Map inserted)")
      success "Knowledge Map inserted into CLAUDE.md. Backup at ${_claude_backup}."
    else
      warn "CLAUDE.md not found — skipping Knowledge Map."
    fi
  fi

  # ── Apply: core-beliefs.md ──────────────────────────────────────────
  if _selected "core-beliefs"; then
    if [[ -d "docs/design-docs" ]] && [[ -f "${TEMPLATE_DIR}/docs/design-docs/core-beliefs.md" ]]; then
      info "Creating core-beliefs.md..."
      cp "${TEMPLATE_DIR}/docs/design-docs/core-beliefs.md" docs/design-docs/core-beliefs.md
      sed -i.bak -e "s|{{PROJECT_NAME}}|${PROJECT_NAME}|g" \
        docs/design-docs/core-beliefs.md && rm docs/design-docs/core-beliefs.md.bak
      CREATED_FILES+=("docs/design-docs/core-beliefs.md")
      CREATED_DESCS+=("docs/design-docs/core-beliefs.md")
      success "core-beliefs.md created."
    else
      [[ ! -d "docs/design-docs" ]] && warn "docs/design-docs/ does not exist — skipping core-beliefs.md."
    fi
  fi

  # ── Apply: QUALITY_SCORE.md ─────────────────────────────────────────
  if _selected "quality-score"; then
    if [[ -d "docs" ]] && [[ -f "${TEMPLATE_DIR}/docs/QUALITY_SCORE.md" ]]; then
      info "Creating QUALITY_SCORE.md..."
      cp "${TEMPLATE_DIR}/docs/QUALITY_SCORE.md" docs/QUALITY_SCORE.md
      sed -i.bak -e "s|{{PROJECT_NAME}}|${PROJECT_NAME}|g" \
        docs/QUALITY_SCORE.md && rm docs/QUALITY_SCORE.md.bak
      CREATED_FILES+=("docs/QUALITY_SCORE.md")
      CREATED_DESCS+=("docs/QUALITY_SCORE.md")
      success "QUALITY_SCORE.md created."
    else
      [[ ! -d "docs" ]] && warn "docs/ does not exist — skipping QUALITY_SCORE.md."
    fi
  fi

  # ── Apply: structural_validation in core-config.yaml (AC6) ──────────
  if _selected "structural-validation"; then
    info "Appending structural_validation to core-config.yaml..."
    _config_backup=$(_safe_backup bmad/config/core-config.yaml)
    cat >> bmad/config/core-config.yaml << 'STRUCT_EOF'

structural_validation:
  enabled: false  # Set true when validation scripts exist
  checks:
    # Uncomment and configure checks for your project:
    # - name: "Dependency Direction"
    #   command: "python lints/check_dependencies.py"
    # - name: "File Size Limits"
    #   command: "python lints/check_file_sizes.py --max 300"
    # - name: "Naming Conventions"
    #   command: "python lints/check_naming.py"
    # - name: "Boundary Validation"
    #   command: "python lints/check_boundaries.py"
STRUCT_EOF
    MODIFIED_DESCS+=("bmad/config/core-config.yaml (structural_validation appended)")
    success "structural_validation added to core-config.yaml. Backup at ${_config_backup}."
  fi

  # ── Apply: tech-debt-tracker.md ─────────────────────────────────────
  if _selected "tech-debt-tracker"; then
    if [[ -d "docs/exec-plans" ]] && [[ -f "${TEMPLATE_DIR}/docs/exec-plans/tech-debt-tracker.md" ]]; then
      info "Creating tech-debt-tracker.md..."
      cp "${TEMPLATE_DIR}/docs/exec-plans/tech-debt-tracker.md" docs/exec-plans/tech-debt-tracker.md
      sed -i.bak -e "s|{{PROJECT_NAME}}|${PROJECT_NAME}|g" \
        docs/exec-plans/tech-debt-tracker.md && rm docs/exec-plans/tech-debt-tracker.md.bak
      CREATED_FILES+=("docs/exec-plans/tech-debt-tracker.md")
      CREATED_DESCS+=("docs/exec-plans/tech-debt-tracker.md")
      success "tech-debt-tracker.md created."
    else
      [[ ! -d "docs/exec-plans" ]] && warn "docs/exec-plans/ does not exist — skipping tech-debt-tracker.md."
    fi
  fi

  # ── Apply: lints/ scaffold ──────────────────────────────────────────
  if _selected "lints-scaffold"; then
    info "Creating lints/ directory with starter scripts..."
    # Detect stack from core-config.yaml (fragile grep — falls back to python)
    _lint_stack=$(grep -E '^\s+language:' bmad/config/core-config.yaml 2>/dev/null | head -1 | sed 's/.*language: *"\{0,1\}\([^"]*\)"\{0,1\}/\1/')
    _scaffold_lints "${_lint_stack}"
    CREATED_FILES+=("lints/README.md")
    CREATED_DESCS+=("lints/ directory with starter validation scripts")
    success "lints/ directory created with ${_lint_stack:-python} starter scripts."
  fi

  # ── Apply: Living-document sections in epic template ─────────────────
  if _selected "living-docs"; then
    if [[ -f "bmad/config/templates/epic-template.md" ]]; then
      info "Adding living-document sections to epic template..."
      _epic_backup=$(_safe_backup bmad/config/templates/epic-template.md)

      _appended=false

      if ! grep -q "## Progress" bmad/config/templates/epic-template.md; then
        cat >> bmad/config/templates/epic-template.md << 'LIVING_PROGRESS'

---

<!-- Living-document sections — update these as the epic progresses. -->

## Progress

<!-- Updated at every major milestone. Use ISO dates. -->

- [ ] (YYYY-MM-DD) Epic created and stories defined
- [ ] (YYYY-MM-DD) Story 001 complete
<!-- Add rows as stories are completed or milestones reached. -->
LIVING_PROGRESS
        _appended=true
      fi

      if ! grep -q "## Surprises" bmad/config/templates/epic-template.md; then
        cat >> bmad/config/templates/epic-template.md << 'LIVING_SURPRISES'

## Surprises & Discoveries

<!-- Unexpected behaviors, performance tradeoffs, API quirks, or bugs discovered
     during implementation. Future agent sessions will read this to avoid repeating
     mistakes. -->

_None yet._
LIVING_SURPRISES
        _appended=true
      fi

      if ! grep -q "## Decision Log" bmad/config/templates/epic-template.md; then
        cat >> bmad/config/templates/epic-template.md << 'LIVING_DECISIONS'

## Decision Log

<!-- Every significant design decision with rationale. When an agent or engineer
     makes a choice that wasn't obvious, record it here so future sessions
     understand WHY. -->

| Date | Decision | Rationale | Alternatives Considered |
|------|----------|-----------|------------------------|
| | | | |
LIVING_DECISIONS
        _appended=true
      fi

      if ! grep -q "## Outcomes" bmad/config/templates/epic-template.md; then
        cat >> bmad/config/templates/epic-template.md << 'LIVING_OUTCOMES'

## Outcomes & Retrospective

<!-- Summary at major milestones or epic completion. Compare the actual result
     against the original Business Value statement. What worked? What would you
     do differently? -->

_To be filled at epic completion._
LIVING_OUTCOMES
        _appended=true
      fi

      if [[ "${_appended}" == true ]]; then
        MODIFIED_DESCS+=("bmad/config/templates/epic-template.md (living-document sections appended)")
        success "Living-document sections added to epic template."
      else
        rm -f "${_epic_backup}"
      fi
    fi
  fi

  # ─── Placeholder sweep on newly created files ─────────────────────────
  for _f in ${CREATED_FILES[@]+"${CREATED_FILES[@]}"}; do
    if [[ -f "${_f}" ]] && grep -qE '\{\{[A-Z0-9_]+\}\}' "${_f}" 2>/dev/null; then
      sed -i.bak -E 's/\{\{([A-Z0-9_]+)\}\}/<!-- TODO: Fill in \1. Run \/configure to auto-detect. -->/g' "${_f}" && rm -f "${_f}.bak"
    fi
  done

  # ─── Summary ──────────────────────────────────────────────────────────
  echo ""
  echo -e "${GREEN}${BOLD}╔══════════════════════════════════════════╗${NC}"
  echo -e "${GREEN}${BOLD}║         BMAD Upgrade Complete             ║${NC}"
  echo -e "${GREEN}${BOLD}╚══════════════════════════════════════════╝${NC}"
  echo ""

  if [[ ${#CREATED_DESCS[@]} -gt 0 ]]; then
    echo -e "${BOLD}Files created:${NC}"
    for item in ${CREATED_DESCS[@]+"${CREATED_DESCS[@]}"}; do
      echo -e "  ${GREEN}+${NC} ${item}"
    done
    echo ""
  fi

  if [[ ${#MODIFIED_DESCS[@]} -gt 0 ]]; then
    echo -e "${BOLD}Files modified:${NC}"
    for item in ${MODIFIED_DESCS[@]+"${MODIFIED_DESCS[@]}"}; do
      echo -e "  ${YELLOW}~${NC} ${item}"
    done
    echo ""
  fi

  echo -e "${BOLD}Recommended next steps:${NC}"
  for item in ${CREATED_DESCS[@]+"${CREATED_DESCS[@]}"}; do
    case "${item}" in
      ARCHITECTURE*) echo "  • Edit ARCHITECTURE.md to describe your system's structure" ;;
      *golden-principles*) echo "  • Customize golden-principles.md for your project's taste" ;;
      *core-beliefs*) echo "  • Review core-beliefs.md and adjust operating principles" ;;
      *QUALITY_SCORE*) echo "  • Set initial quality scores in QUALITY_SCORE.md" ;;
      *tech-debt*) echo "  • Log known tech debt in tech-debt-tracker.md" ;;
      "docs/ directory"*) echo "  • Populate docs/ with design documents and references" ;;
      *lints*) echo "  • Customize lint scripts in lints/ for your architecture's layer boundaries" ;;
    esac
  done
  for item in ${MODIFIED_DESCS[@]+"${MODIFIED_DESCS[@]}"}; do
    case "${item}" in
      *Knowledge*) echo "  • Review Knowledge Map in CLAUDE.md and add project-specific entries" ;;
      *structural*) echo "  • Enable structural_validation rules in core-config.yaml when ready" ;;
      *living*) echo "  • Use living-document sections in future epics" ;;
    esac
  done
  echo "  • Run /configure to auto-detect remaining settings"
  echo ""

  exit 0
fi

# ─── Interactive prompts ───────────────────────────────────────────────────────
DEFAULT_NAME="$(basename "${REPO_ROOT}")"

if [[ -z "${PROJECT_NAME}" ]] && [[ "${NON_INTERACTIVE}" == false ]]; then
  prompt "Project name? [${DEFAULT_NAME}]"
  read -r input
  PROJECT_NAME="${input:-${DEFAULT_NAME}}"
fi
PROJECT_NAME="${PROJECT_NAME:-${DEFAULT_NAME}}"

if [[ -z "${DESCRIPTION}" ]] && [[ "${NON_INTERACTIVE}" == false ]]; then
  prompt "One-line project description?"
  read -r DESCRIPTION
fi
DESCRIPTION="${DESCRIPTION:-A software project using BMAD story-driven development.}"

if [[ -z "${PRIMARY_STACK}" ]] && [[ "${NON_INTERACTIVE}" == false ]]; then
  echo ""
  echo "  1) python"
  echo "  2) typescript"
  echo "  3) go"
  echo "  4) other"
  prompt "Primary language? [1]"
  read -r stack_choice
  case "${stack_choice}" in
    2) PRIMARY_STACK="typescript" ;;
    3) PRIMARY_STACK="go" ;;
    4) PRIMARY_STACK="other" ;;
    *) PRIMARY_STACK="python" ;;
  esac
fi
PRIMARY_STACK="${PRIMARY_STACK:-python}"

if [[ -z "${SPECIALISTS_RAW}" ]] && [[ "${NON_INTERACTIVE}" == false ]]; then
  echo ""
  echo "  Available specialists: backend, frontend, data, qa, infra"
  prompt "Which specialists? (comma-separated) [backend,qa]"
  read -r SPECIALISTS_RAW
fi
SPECIALISTS_RAW="${SPECIALISTS_RAW:-backend,qa}"

# ─── Architecture pattern ────────────────────────────────────────────────────
if [[ -z "${ARCH_PATTERN}" ]] && [[ "${NON_INTERACTIVE}" == false ]]; then
  echo ""
  echo "  1) monolith"
  echo "  2) monorepo"
  echo "  3) microservices"
  echo "  4) serverless"
  echo "  5) library/package"
  prompt "Architecture pattern? [1]"
  read -r arch_choice
  case "${arch_choice}" in
    2) ARCH_PATTERN="monorepo" ;;
    3) ARCH_PATTERN="microservices" ;;
    4) ARCH_PATTERN="serverless" ;;
    5) ARCH_PATTERN="library" ;;
    *) ARCH_PATTERN="monolith" ;;
  esac
fi
ARCH_PATTERN="${ARCH_PATTERN:-monolith}"

# ─── Database ────────────────────────────────────────────────────────────────
if [[ -z "${DATABASE}" ]] && [[ "${NON_INTERACTIVE}" == false ]]; then
  echo ""
  echo "  1) postgres"
  echo "  2) mysql"
  echo "  3) sqlite"
  echo "  4) mongodb"
  echo "  5) none"
  prompt "Database? [5]"
  read -r db_choice
  case "${db_choice}" in
    1) DATABASE="postgres" ;;
    2) DATABASE="mysql" ;;
    3) DATABASE="sqlite" ;;
    4) DATABASE="mongodb" ;;
    *) DATABASE="none" ;;
  esac
fi
DATABASE="${DATABASE:-none}"

# ─── Stack defaults ────────────────────────────────────────────────────────────
case "${PRIMARY_STACK}" in
  python)
    TEST_CMD="pytest"
    LINT_CMD="ruff check ."
    FORMAT_CHECK_CMD="ruff format --check ."
    FORMAT_FIX_CMD="ruff check --fix ."
    ENV_ACTIVATE_CMD="source venv/bin/activate"
    DEPS_INSTALL_CMD="pip install -r requirements.txt"
    APP_LAUNCH_CMD="python main.py  # or: streamlit run app.py / uvicorn app:app"
    SETUP_CMDS="python -m venv venv\nsource venv/bin/activate\npip install -r requirements.txt"
    ;;
  typescript)
    TEST_CMD="npm test"
    LINT_CMD="eslint ."
    FORMAT_CHECK_CMD="prettier --check ."
    FORMAT_FIX_CMD="prettier --write ."
    ENV_ACTIVATE_CMD="# (no activation needed)"
    DEPS_INSTALL_CMD="npm install"
    APP_LAUNCH_CMD="npm run dev"
    SETUP_CMDS="npm install"
    ;;
  go)
    TEST_CMD="go test ./..."
    LINT_CMD="golangci-lint run"
    FORMAT_CHECK_CMD="gofmt -l ."
    FORMAT_FIX_CMD="gofmt -w ."
    ENV_ACTIVATE_CMD="# (no activation needed)"
    DEPS_INSTALL_CMD="go mod download"
    APP_LAUNCH_CMD="go run main.go"
    SETUP_CMDS="go mod download"
    ;;
  *)
    TEST_CMD="make test"
    LINT_CMD="make lint"
    FORMAT_CHECK_CMD="make format-check"
    FORMAT_FIX_CMD="make format"
    ENV_ACTIVATE_CMD="# configure for your stack"
    DEPS_INSTALL_CMD="# install dependencies"
    APP_LAUNCH_CMD="# launch command"
    SETUP_CMDS="# setup steps"
    ;;
esac

# ─── Parse specialists ─────────────────────────────────────────────────────────
IFS=',' read -ra SPECIALIST_LIST <<< "${SPECIALISTS_RAW}"
SPECIALIST_LIST=("${SPECIALIST_LIST[@]// /}")  # trim spaces

# ─── Framework-specific prompts (conditional on specialists) ─────────────────
if [[ "${NON_INTERACTIVE}" == false ]]; then
  for spec in "${SPECIALIST_LIST[@]}"; do
    case "${spec}" in
      backend)
        if [[ -z "${BACKEND_FRAMEWORK}" ]]; then
          echo ""
          prompt "Backend framework? (e.g., fastapi, django, express, gin) [${PRIMARY_STACK} default]"
          read -r BACKEND_FRAMEWORK
        fi
        ;;
      frontend)
        if [[ -z "${FRONTEND_FRAMEWORK}" ]]; then
          echo ""
          prompt "Frontend framework? (e.g., react, vue, angular, svelte, nextjs) []"
          read -r FRONTEND_FRAMEWORK
        fi
        ;;
      data)
        if [[ -z "${DATA_TOOLS}" ]]; then
          echo ""
          prompt "Data tools? (e.g., pandas, sqlalchemy, spark, dbt) []"
          read -r DATA_TOOLS
        fi
        ;;
    esac
  done
fi

# Set defaults based on stack if not provided
if [[ -z "${BACKEND_FRAMEWORK}" ]]; then
  case "${PRIMARY_STACK}" in
    python)     BACKEND_FRAMEWORK="Python" ;;
    typescript) BACKEND_FRAMEWORK="TypeScript" ;;
    go)         BACKEND_FRAMEWORK="Go" ;;
    *)          BACKEND_FRAMEWORK="${PRIMARY_STACK}" ;;
  esac
fi
FRONTEND_FRAMEWORK="${FRONTEND_FRAMEWORK:-}"
DATA_TOOLS="${DATA_TOOLS:-}"

# ─── Auto-detect key directories ─────────────────────────────────────────────
DETECTED_DIRS=""
for dir in src server web lib app api cmd pkg internal tests test spec public; do
  [[ -d "${dir}" ]] && DETECTED_DIRS="${DETECTED_DIRS} ${dir}/"
done

if [[ -n "${DETECTED_DIRS}" ]] && [[ "${NON_INTERACTIVE}" == false ]]; then
  info "Detected directories:${DETECTED_DIRS}"
  prompt "Include in key files? [Y/n]"
  read -r confirm
  [[ "${confirm}" =~ ^[Nn]$ ]] && DETECTED_DIRS=""
fi

# ─── Portable capitalize helper ───────────────────────────────────────────────
capitalize() { echo "$1" | awk '{print toupper(substr($0,1,1)) substr($0,2)}'; }

# ─── Build architecture summary ──────────────────────────────────────────────
ARCH_CAP="$(capitalize "${ARCH_PATTERN}")"
ARCH_DESC="${ARCH_CAP} ${PRIMARY_STACK} application"
[[ "${BACKEND_FRAMEWORK}" != "${PRIMARY_STACK}" ]] && [[ "${BACKEND_FRAMEWORK}" != "Python" ]] && [[ "${BACKEND_FRAMEWORK}" != "TypeScript" ]] && [[ "${BACKEND_FRAMEWORK}" != "Go" ]] && ARCH_DESC="${ARCH_CAP} ${BACKEND_FRAMEWORK} application"
[[ "${DATABASE}" != "none" ]] && ARCH_DESC="${ARCH_DESC} with ${DATABASE}"
ARCH_DESC="${ARCH_DESC}."

# Build tech stack table rows
TECH_STACK_ROWS="| Language | ${PRIMARY_STACK} |"
[[ -n "${BACKEND_FRAMEWORK}" ]] && TECH_STACK_ROWS="${TECH_STACK_ROWS}\n| Backend  | ${BACKEND_FRAMEWORK} |"
[[ -n "${FRONTEND_FRAMEWORK}" ]] && TECH_STACK_ROWS="${TECH_STACK_ROWS}\n| Frontend | ${FRONTEND_FRAMEWORK} |"
[[ "${DATABASE}" != "none" ]] && TECH_STACK_ROWS="${TECH_STACK_ROWS}\n| Database | ${DATABASE} |"
[[ -n "${DATA_TOOLS}" ]] && TECH_STACK_ROWS="${TECH_STACK_ROWS}\n| Data     | ${DATA_TOOLS} |"

# Build key files table rows from detected dirs
KEY_FILES_ROWS=""
_kf_sep=""
for dir in ${DETECTED_DIRS}; do
  case "${dir}" in
    src/)      KEY_FILES_ROWS="${KEY_FILES_ROWS}${_kf_sep}| Source Code | \`${dir}\` |" ;;
    server/)   KEY_FILES_ROWS="${KEY_FILES_ROWS}${_kf_sep}| Server | \`${dir}\` |" ;;
    web/)      KEY_FILES_ROWS="${KEY_FILES_ROWS}${_kf_sep}| Web Frontend | \`${dir}\` |" ;;
    lib/)      KEY_FILES_ROWS="${KEY_FILES_ROWS}${_kf_sep}| Library | \`${dir}\` |" ;;
    app/)      KEY_FILES_ROWS="${KEY_FILES_ROWS}${_kf_sep}| Application | \`${dir}\` |" ;;
    api/)      KEY_FILES_ROWS="${KEY_FILES_ROWS}${_kf_sep}| API | \`${dir}\` |" ;;
    cmd/)      KEY_FILES_ROWS="${KEY_FILES_ROWS}${_kf_sep}| CLI/Commands | \`${dir}\` |" ;;
    tests/|test/|spec/) KEY_FILES_ROWS="${KEY_FILES_ROWS}${_kf_sep}| Tests | \`${dir}\` |" ;;
    public/)   KEY_FILES_ROWS="${KEY_FILES_ROWS}${_kf_sep}| Static Assets | \`${dir}\` |" ;;
    *)         KEY_FILES_ROWS="${KEY_FILES_ROWS}${_kf_sep}| ${dir%/} | \`${dir}\` |" ;;
  esac
  _kf_sep="\n"
done

# ─── Create directory structure ────────────────────────────────────────────────
info "Creating BMAD directory structure..."
mkdir -p bmad/config/workflows
mkdir -p bmad/config/tasks
mkdir -p bmad/config/templates
mkdir -p bmad/config/checklists
mkdir -p bmad/config/agents/active
mkdir -p bmad/epics

# ─── Copy template files ────────────────────────────────────────────────────────
info "Copying workflow, task, template, and checklist files..."
cp "${TEMPLATE_DIR}/workflows/"*.md bmad/config/workflows/
cp "${TEMPLATE_DIR}/tasks/"*.md bmad/config/tasks/
cp "${TEMPLATE_DIR}/templates/"* bmad/config/templates/
cp "${TEMPLATE_DIR}/checklists/"*.md bmad/config/checklists/

# Replace placeholders in checklist files
for f in bmad/config/checklists/*.md; do
  sed -i.bak \
    -e "s|{{ENV_ACTIVATE_CMD}}|${ENV_ACTIVATE_CMD}|g" \
    -e "s|{{DEPS_INSTALL_CMD}}|${DEPS_INSTALL_CMD}|g" \
    -e "s|{{APP_LAUNCH_CMD}}|${APP_LAUNCH_CMD}|g" \
    -e "s|{{TEST_CMD}}|${TEST_CMD}|g" \
    -e "s|{{LINT_CMD}}|${LINT_CMD}|g" \
    -e "s|{{FORMAT_CMD}}|${FORMAT_CHECK_CMD}|g" \
    "${f}" && rm "${f}.bak"
done

# ─── Copy ARCHITECTURE.md to repo root ─────────────────────────────────────────
if [[ ! -f "ARCHITECTURE.md" ]]; then
  if [[ -f "${TEMPLATE_DIR}/templates/architecture-template.md" ]]; then
    info "Creating ARCHITECTURE.md..."
    cp "${TEMPLATE_DIR}/templates/architecture-template.md" ARCHITECTURE.md
    sed -i.bak \
      -e "s|{{PROJECT_NAME}}|${PROJECT_NAME}|g" \
      -e "s|{{PROJECT_DESCRIPTION}}|${DESCRIPTION}|g" \
      ARCHITECTURE.md && rm ARCHITECTURE.md.bak
    success "ARCHITECTURE.md created at repo root. Customize it for your project."
  fi
else
  warn "ARCHITECTURE.md already exists — skipping."
fi

# ─── Copy golden-principles.md to bmad/config/ ──────────────────────────────
if [[ -f "${TEMPLATE_DIR}/templates/golden-principles.md" ]]; then
  info "Creating golden-principles.md..."
  cp "${TEMPLATE_DIR}/templates/golden-principles.md" bmad/config/golden-principles.md
  sed -i.bak \
    -e "s|{{PROJECT_NAME}}|${PROJECT_NAME}|g" \
    bmad/config/golden-principles.md && rm bmad/config/golden-principles.md.bak
  success "bmad/config/golden-principles.md created."
fi

# Replace placeholders in task files
for f in bmad/config/tasks/*.md; do
  sed -i.bak \
    -e "s|{{TEST_COMMAND}}|${TEST_CMD}|g" \
    -e "s|{{LINT_COMMAND}}|${LINT_CMD}|g" \
    -e "s|{{APP_LAUNCH_COMMAND}}|${APP_LAUNCH_CMD}|g" \
    "${f}" && rm "${f}.bak"
done

# Replace placeholders in workflow files
for f in bmad/config/workflows/*.md; do
  sed -i.bak \
    -e "s|{{PROJECT_NAME}}|${PROJECT_NAME}|g" \
    -e "s|{{TEST_COMMAND}}|${TEST_CMD}|g" \
    -e "s|{{LINT_COMMAND}}|${LINT_CMD}|g" \
    -e "s|{{APP_LAUNCH_COMMAND}}|${APP_LAUNCH_CMD}|g" \
    "${f}" && rm "${f}.bak"
done

# Replace specialist table in bmad-flow.md with actual specialist list
if [[ -f "bmad/config/workflows/bmad-flow.md" ]]; then
  FLOW_TABLE_TMP=$(mktemp)
  for spec in "${SPECIALIST_LIST[@]}"; do
    spec_cap="$(capitalize "${spec}")"
    echo "| **${spec_cap} Specialist** | ${spec_cap} domain expertise |" >> "${FLOW_TABLE_TMP}"
  done

  awk -v table_file="${FLOW_TABLE_TMP}" '
    /<!-- TODO:.*Replace with your active specialists/ {
      while ((getline line < table_file) > 0) print line
      close(table_file)
      # Consume rest of multi-line HTML comment
      if ($0 !~ /-->/) { while (getline > 0 && $0 !~ /-->/) {} }
      next
    }
    { print }
  ' "bmad/config/workflows/bmad-flow.md" > "bmad/config/workflows/bmad-flow.md.tmp" && \
    mv "bmad/config/workflows/bmad-flow.md.tmp" "bmad/config/workflows/bmad-flow.md"

  rm -f "${FLOW_TABLE_TMP}"
fi

# ─── Derive test framework name ─────────────────────────────────────────────
TEST_FRAMEWORK="${TEST_CMD%% *}"

# ─── Copy and customize specialist agents ──────────────────────────────────────
info "Setting up specialist agents: ${SPECIALISTS_RAW}..."
for spec in "${SPECIALIST_LIST[@]}"; do
  stub_file="${TEMPLATE_DIR}/agents/stubs/${spec}-specialist.md"
  if [[ -f "${stub_file}" ]]; then
    dest="bmad/config/agents/active/${spec}-specialist.md"
    if [[ -f "${dest}" ]]; then
      warn "  Skipping ${spec}-specialist.md (already exists, preserving customizations)"
    else
      cp "${stub_file}" "${dest}"
      # Replace project name, test framework, and specialist-specific placeholders
      SPEC_TECH="" SPEC_FOCUS="" SPEC_FILES=""
      case "${spec}" in
        backend)
          SPEC_TECH="${BACKEND_FRAMEWORK}"
          SPEC_FOCUS="${PROJECT_NAME} backend services"
          SPEC_FILES="$(echo "${DETECTED_DIRS}" | tr ' ' '\n' | grep -E '^(src|server|app|api|lib|cmd)/' | tr '\n' ', ' | sed 's/,$//' || true)"
          ;;
        frontend)
          SPEC_TECH="${FRONTEND_FRAMEWORK:-${PRIMARY_STACK}}"
          SPEC_FOCUS="${PROJECT_NAME} frontend UI"
          SPEC_FILES="$(echo "${DETECTED_DIRS}" | tr ' ' '\n' | grep -E '^(web|public|src|app)/' | tr '\n' ', ' | sed 's/,$//' || true)"
          ;;
        data)
          SPEC_TECH="${DATA_TOOLS:-${PRIMARY_STACK}}"
          SPEC_FOCUS="${PROJECT_NAME} data pipelines and storage"
          SPEC_FILES="$(echo "${DETECTED_DIRS}" | tr ' ' '\n' | grep -E '^(data|src|lib)/' | tr '\n' ', ' | sed 's/,$//' || true)"
          ;;
        infra)
          SPEC_TECH="Infrastructure"
          SPEC_FOCUS="${PROJECT_NAME} deployment and operations"
          SPEC_FILES="Dockerfile, docker-compose.yml, terraform/, .github/workflows/"
          ;;
      esac

      sed -i.bak \
        -e "s|{{PROJECT_NAME}}|${PROJECT_NAME}|g" \
        -e "s|{{TEST_FRAMEWORK}}|${TEST_FRAMEWORK}|g" \
        "${dest}" && rm "${dest}.bak"

      # Replace specialist-specific TODO markers if we have values
      if [[ -n "${SPEC_TECH}" ]]; then
        UPPER_SPEC="$(echo "${spec}" | tr '[:lower:]' '[:upper:]')"
        sed -i.bak \
          -e "s|<!-- TODO: e.g.,.* --> implementation patterns|${SPEC_TECH} implementation patterns|g" \
          -e "s|<!-- TODO: e.g.,.* --> components and state|${SPEC_TECH} components and state|g" \
          -e "s|<!-- TODO: e.g.,.* --> data processing|${SPEC_TECH} data processing|g" \
          -e "s|<!-- TODO: e.g.,.* --> deployment and configuration|${SPEC_TECH} deployment and configuration|g" \
          "${dest}" && rm "${dest}.bak"
      fi
      if [[ -n "${SPEC_FOCUS}" ]]; then
        sed -i.bak \
          -e "s|<!-- TODO: e.g.,.* domain expertise -->|${SPEC_FOCUS}|g" \
          -e "s|<!-- TODO: e.g.,.* API services.*-->|${SPEC_FOCUS}|g" \
          -e "s|<!-- TODO: e.g.,.* UI components.*-->|${SPEC_FOCUS}|g" \
          -e "s|<!-- TODO: e.g.,.* Data pipelines.*-->|${SPEC_FOCUS}|g" \
          -e "s|<!-- TODO: e.g.,.* Deployment.*-->|${SPEC_FOCUS}|g" \
          "${dest}" && rm "${dest}.bak"
      fi
      if [[ -n "${SPEC_FILES}" ]]; then
        sed -i.bak \
          -e "s|<!-- TODO: e.g.,.* app/api/.*-->|${SPEC_FILES}|g" \
          -e "s|<!-- TODO: e.g.,.* src/components/.*-->|${SPEC_FILES}|g" \
          -e "s|<!-- TODO: e.g.,.* app/data/.*-->|${SPEC_FILES}|g" \
          -e "s|<!-- TODO: e.g.,.* Dockerfile.*-->|${SPEC_FILES}|g" \
          "${dest}" && rm "${dest}.bak"
      fi

      success "  Created ${dest}"
    fi
  else
    warn "  No stub found for '${spec}' — creating blank agent file"
    SPEC_CAP="$(capitalize "${spec}")"
    cat > "bmad/config/agents/active/${spec}-specialist.md" << EOF
# ${SPEC_CAP} Specialist - ${PROJECT_NAME}

ACTIVATION-NOTICE: Load this persona when working on ${spec} concerns.

**Domain**: ${spec}
**Project**: ${PROJECT_NAME}

## Expertise
- [Define ${spec} focus areas]

## Quality Gates
- [ ] [Define ${spec}-specific quality criteria]
EOF
  fi
done

# ─── Create BMAD Master ────────────────────────────────────────────────────────
if [[ ! -f "bmad/config/agents/bmad-master.md" ]]; then
  info "Creating BMAD Master agent..."
  cp "${TEMPLATE_DIR}/agents/bmad-master.md" bmad/config/agents/bmad-master.md

  sed -i.bak \
    -e "s|{{PROJECT_NAME}}|${PROJECT_NAME}|g" \
    -e "s|{{PROJECT_DESCRIPTION}}|${DESCRIPTION}|g" \
    -e "s|{{PROJECT_DOMAIN}}|${PROJECT_NAME}|g" \
    "bmad/config/agents/bmad-master.md" && rm "bmad/config/agents/bmad-master.md.bak"

  # Build specialist content files for awk-based replacement
  SPEC_LIST_TMP=$(mktemp)
  SPEC_TABLE_TMP=$(mktemp)

  for spec in "${SPECIALIST_LIST[@]}"; do
    echo "    - ${spec}-specialist.md" >> "${SPEC_LIST_TMP}"
  done

  {
    echo "| Agent | Focus Area |"
    echo "|-------|------------|"
    for spec in "${SPECIALIST_LIST[@]}"; do
      spec_cap="$(capitalize "${spec}")"
      echo "| **${spec_cap} Specialist** | ${spec_cap} domain expertise |"
    done
  } > "${SPEC_TABLE_TMP}"

  # Replace {{SPECIALIST_AGENTS_LIST}} and {{SPECIALIST_AGENTS_TABLE}} using awk
  awk -v list_file="${SPEC_LIST_TMP}" -v table_file="${SPEC_TABLE_TMP}" '
    /\{\{SPECIALIST_AGENTS_LIST\}\}/ {
      while ((getline line < list_file) > 0) print line
      close(list_file)
      next
    }
    /\{\{SPECIALIST_AGENTS_TABLE\}\}/ {
      while ((getline line < table_file) > 0) print line
      close(table_file)
      next
    }
    { print }
  ' "bmad/config/agents/bmad-master.md" > "bmad/config/agents/bmad-master.md.tmp" && \
    mv "bmad/config/agents/bmad-master.md.tmp" "bmad/config/agents/bmad-master.md"

  rm -f "${SPEC_LIST_TMP}" "${SPEC_TABLE_TMP}"

  # Append specialist reference list to BMAD master
  {
    echo ""
    echo "### Active Specialists"
    for spec in "${SPECIALIST_LIST[@]}"; do
      echo "- $(capitalize "${spec}") Specialist: see \`bmad/config/agents/active/${spec}-specialist.md\`"
    done
  } >> bmad/config/agents/bmad-master.md
fi

# ─── Create core-config.yaml ────────────────────────────────────────────────────
info "Creating core-config.yaml..."

cp "${TEMPLATE_DIR}/core-config.yaml.template" bmad/config/core-config.yaml
sed -i.bak \
  -e "s|{{PROJECT_NAME}}|${PROJECT_NAME}|g" \
  -e "s|{{PROJECT_DESCRIPTION}}|${DESCRIPTION}|g" \
  -e "s|{{PRIMARY_LANGUAGE}}|${PRIMARY_STACK}|g" \
  -e "s|{{TEST_COMMAND}}|${TEST_CMD}|g" \
  -e "s|{{LINT_COMMAND}}|${LINT_CMD}|g" \
  -e "s|{{FORMAT_CHECK_COMMAND}}|${FORMAT_CHECK_CMD}|g" \
  -e "s|{{APP_LAUNCH_COMMAND}}|${APP_LAUNCH_CMD}|g" \
  -e "s|{{ENV_ACTIVATE_CMD}}|${ENV_ACTIVATE_CMD}|g" \
  bmad/config/core-config.yaml && rm bmad/config/core-config.yaml.bak
# Append specialists section to core-config
echo "" >> bmad/config/core-config.yaml
echo "specialists:" >> bmad/config/core-config.yaml
for spec in "${SPECIALIST_LIST[@]}"; do
  echo "  - ${spec}" >> bmad/config/core-config.yaml
done

# ─── Full docs/ scaffold (--full flag) ─────────────────────────────────────────
if [[ "${FULL_SCAFFOLD}" == true ]]; then
  info "Scaffolding full docs/ knowledge base..."
  mkdir -p docs/design-docs docs/exec-plans/active docs/exec-plans/completed \
           docs/product-specs docs/references docs/generated

  # Copy and customize template files
  _docs_templates=(
    "docs/design-docs/core-beliefs.md"
    "docs/design-docs/index.md"
    "docs/product-specs/index.md"
    "docs/references/README.md"
    "docs/exec-plans/tech-debt-tracker.md"
    "docs/QUALITY_SCORE.md"
  )
  for _tpl in "${_docs_templates[@]}"; do
    if [[ -f "${TEMPLATE_DIR}/${_tpl}" ]]; then
      cp "${TEMPLATE_DIR}/${_tpl}" "${_tpl}"
      sed -i.bak -e "s|{{PROJECT_NAME}}|${PROJECT_NAME}|g" "${_tpl}" && rm "${_tpl}.bak"
    fi
  done

  # Ensure generated/ dir is tracked even when empty
  if [[ -f "${TEMPLATE_DIR}/docs/generated/.gitkeep" ]]; then
    cp "${TEMPLATE_DIR}/docs/generated/.gitkeep" docs/generated/.gitkeep
  else
    touch docs/generated/.gitkeep
  fi

  success "docs/ directory scaffolded: design-docs, exec-plans, product-specs, references, generated"

  # ─── Lint scaffold (part of --full) ──────────────────────────────────────────
  info "Scaffolding lints/ directory..."
  _scaffold_lints "${PRIMARY_STACK}"
  success "lints/ directory scaffolded with ${PRIMARY_STACK:-python} starter scripts"
fi

# ─── Generate CLAUDE.md ────────────────────────────────────────────────────────
if [[ -f "CLAUDE.md" ]]; then
  warn "CLAUDE.md already exists — skipping generation. Edit manually or delete and re-run."
else
  info "Generating CLAUDE.md..."
  cp "${TEMPLATE_DIR}/CLAUDE.md.template" CLAUDE.md
  sed -i.bak \
    -e "s|{{PROJECT_NAME}}|${PROJECT_NAME}|g" \
    -e "s|{{PROJECT_DESCRIPTION}}|${DESCRIPTION}|g" \
    -e "s|{{TEST_COMMAND}}|${TEST_CMD}|g" \
    -e "s|{{TEST_FRAMEWORK}}|${TEST_CMD%% *}|g" \
    -e "s|{{LINT_COMMAND}}|${LINT_CMD}|g" \
    -e "s|{{FORMAT_CHECK_COMMAND}}|${FORMAT_CHECK_CMD}|g" \
    -e "s|{{APP_LAUNCH_COMMAND}}|${APP_LAUNCH_CMD}|g" \
    -e "s|{{SETUP_COMMANDS}}|${SETUP_CMDS}|g" \
    -e "s|{{ARCHITECTURE_SUMMARY}}|${ARCH_DESC}|g" \
    CLAUDE.md && rm CLAUDE.md.bak

  # Replace multi-line placeholders using Python for cross-platform reliability
  python3 -c "
import sys
content = open('CLAUDE.md').read()
tech = '''$(printf '%b' "${TECH_STACK_ROWS}")'''
keys = '''$(printf '%b' "${KEY_FILES_ROWS}")'''
content = content.replace('{{TECH_STACK_TABLE}}', tech)
if keys.strip():
    content = content.replace('{{KEY_FILES_TABLE}}', keys)
open('CLAUDE.md', 'w').write(content)
"

  success "CLAUDE.md created with detected settings. Review and customize as needed."
fi

# ─── Gitignore prompt ─────────────────────────────────────────────────────────
if [[ -z "${GITIGNORE_BMAD}" ]] && [[ "${NON_INTERACTIVE}" == false ]]; then
  echo ""
  prompt "Add BMAD files to .gitignore? (recommended for existing/corporate repos) [y/N]"
  read -r gi_confirm
  [[ "${gi_confirm}" =~ ^[Yy]$ ]] && GITIGNORE_BMAD="yes" || GITIGNORE_BMAD="no"
fi
GITIGNORE_BMAD="${GITIGNORE_BMAD:-no}"

# ─── Update .gitignore ────────────────────────────────────────────────────────
if [[ "${GITIGNORE_BMAD}" == "yes" ]]; then
  # Ensure .gitignore exists
  touch .gitignore

  if ! grep -q '^CLAUDE\.md$' .gitignore 2>/dev/null; then
    {
      echo ""
      echo "# BMAD framework (local dev tooling)"
      echo "CLAUDE.md"
      echo "bmad/"
    } >> .gitignore
    success "Added CLAUDE.md and bmad/ to .gitignore"
  fi
else
  # Even when committing BMAD files, ignore draft stories
  if [[ -f ".gitignore" ]]; then
    if ! grep -q "bmad/epics/\*/stories/\.draft/" .gitignore 2>/dev/null; then
      {
        echo ""
        echo "# BMAD draft stories"
        echo "bmad/epics/*/stories/.draft/"
      } >> .gitignore
      info "Updated .gitignore"
    fi
  fi
fi

# ─── Catchall: convert remaining {{PLACEHOLDERS}} to TODO markers ─────────────
info "Checking for remaining placeholders..."
REMAINING=0
for f in CLAUDE.md bmad/config/agents/*.md bmad/config/agents/active/*.md bmad/config/workflows/*.md bmad/config/tasks/*.md bmad/config/checklists/*.md bmad/config/*.yaml; do
  if [[ -f "${f}" ]] && grep -qE '\{\{[A-Z0-9_]+\}\}' "${f}" 2>/dev/null; then
    sed -i.bak -E 's/\{\{([A-Z0-9_]+)\}\}/<!-- TODO: Fill in \1. Run \/configure to auto-detect. -->/g' "${f}" && rm -f "${f}.bak"
    count=$(grep -c 'TODO: Fill in' "${f}" 2>/dev/null || true)
    REMAINING=$((REMAINING + count))
  fi
done

if [[ ${REMAINING} -gt 0 ]]; then
  warn "${REMAINING} TODO markers remaining — /configure can auto-fill most of them"
else
  success "All placeholders filled!"
fi

# ─── Summary ─────────────────────────────────────────────────────────────────
echo ""
echo -e "${GREEN}${BOLD}✓ BMAD initialized for: ${PROJECT_NAME}${NC}"
echo ""
echo -e "${BOLD}Configuration:${NC}"
echo "  Project:       ${PROJECT_NAME}"
echo "  Stack:         ${PRIMARY_STACK}${BACKEND_FRAMEWORK:+ ($BACKEND_FRAMEWORK)}"
echo "  Architecture:  ${ARCH_PATTERN}"
echo "  Database:      ${DATABASE}"
echo "  Specialists:   ${SPECIALISTS_RAW}"
echo ""
echo -e "${BOLD}Created:${NC}"
echo "  bmad/config/workflows/     — lifecycle workflows"
echo "  bmad/config/tasks/         — task definitions"
echo "  bmad/config/templates/     — epic + story templates"
echo "  bmad/config/checklists/    — pre/post work checklists"
echo "  bmad/config/agents/        — BMAD master + specialist stubs"
echo "  bmad/config/golden-principles.md — code taste rules"
echo "  bmad/epics/                 — empty, ready for first epic"
[[ ! -f "ARCHITECTURE.md" ]] || echo "  ARCHITECTURE.md             — architecture documentation (edit this!)"
[[ ! -f "CLAUDE.md" ]] || echo "  CLAUDE.md                   — project instructions (edit this!)"
[[ "${FULL_SCAFFOLD}" == true ]] && echo "  docs/                       — knowledge base (design-docs, exec-plans, etc.)"
[[ "${FULL_SCAFFOLD}" == true ]] && echo "  lints/                      — custom structural validation scripts"
echo ""
echo -e "${BOLD}Next steps:${NC}"
echo "  1. Open Claude Code:  claude"
echo "  2. Auto-configure:    /configure"
echo "  3. Review settings:   edit CLAUDE.md and ARCHITECTURE.md"
echo "  4. Start building:    /epic <your-first-feature>"
echo ""
echo -e "${CYAN}Commands available everywhere:${NC} /bmad /epic /story /implement /explore /think /review /simplify /configure"
