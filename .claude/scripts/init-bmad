#!/usr/bin/env bash
# init-bmad — Bootstrap BMAD story-driven development framework in a new project
# Usage: init-bmad [--name "Project Name"] [--stack python|typescript|go|other]
#                  [--specialists "backend,data,qa"] [--non-interactive]
# Source: ~/.claude/scripts/init-bmad

set -euo pipefail

TEMPLATE_DIR="${HOME}/.claude/bmad-template"
SCRIPT_NAME="init-bmad"

# ─── Colors ───────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# ─── Helpers ──────────────────────────────────────────────────────────────────
info()    { echo -e "${BLUE}[init-bmad]${NC} $*"; }
success() { echo -e "${GREEN}[init-bmad]${NC} $*"; }
warn()    { echo -e "${YELLOW}[init-bmad]${NC} $*"; }
error()   { echo -e "${RED}[init-bmad] ERROR:${NC} $*" >&2; exit 1; }
prompt()  { echo -e "${CYAN}${BOLD}?${NC} $*"; }

# ─── Pre-flight ───────────────────────────────────────────────────────────────
if [[ ! -d "${TEMPLATE_DIR}" ]]; then
  error "Template directory not found: ${TEMPLATE_DIR}\nRun: ls ~/.claude/bmad-template to verify install."
fi

if ! git rev-parse --git-dir > /dev/null 2>&1; then
  error "Not inside a git repository. Run 'git init' first or cd into an existing repo."
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
if [[ "$(pwd)" != "${REPO_ROOT}" ]]; then
  warn "You are not in the repo root. Running from: ${REPO_ROOT}"
  cd "${REPO_ROOT}" || error "Cannot cd to repo root"
fi

if [[ -d "bmad/qf-bmad" ]]; then
  warn "bmad/qf-bmad already exists. Re-running will overwrite workflow/task/template files but preserve epics and agent customizations."
  read -r -p "Continue? [y/N] " confirm
  [[ "${confirm}" =~ ^[Yy]$ ]] || { info "Aborted."; exit 0; }
fi

# ─── Argument parsing ─────────────────────────────────────────────────────────
PROJECT_NAME=""
PRIMARY_STACK=""
SPECIALISTS_RAW=""
NON_INTERACTIVE=false
DESCRIPTION=""
ARCH_PATTERN=""
BACKEND_FRAMEWORK=""
FRONTEND_FRAMEWORK=""
DATA_TOOLS=""
DATABASE=""
GITIGNORE_BMAD=""
FULL_SCAFFOLD=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --name)               PROJECT_NAME="$2"; shift 2 ;;
    --stack)              PRIMARY_STACK="$2"; shift 2 ;;
    --specialists)        SPECIALISTS_RAW="$2"; shift 2 ;;
    --desc)               DESCRIPTION="$2"; shift 2 ;;
    --arch)               ARCH_PATTERN="$2"; shift 2 ;;
    --backend-framework)  BACKEND_FRAMEWORK="$2"; shift 2 ;;
    --frontend-framework) FRONTEND_FRAMEWORK="$2"; shift 2 ;;
    --data-tools)         DATA_TOOLS="$2"; shift 2 ;;
    --database)           DATABASE="$2"; shift 2 ;;
    --gitignore)          GITIGNORE_BMAD="yes"; shift ;;
    --no-gitignore)       GITIGNORE_BMAD="no"; shift ;;
    --full)               FULL_SCAFFOLD=true; shift ;;
    --non-interactive)    NON_INTERACTIVE=true; shift ;;
    -h|--help)
      echo "Usage: ${SCRIPT_NAME} [options]"
      echo ""
      echo "Options:"
      echo "  --name NAME                 Project name (default: directory name)"
      echo "  --stack STACK               Primary language: python|typescript|go|other"
      echo "  --specialists LIST          Comma-separated: backend,frontend,data,qa,infra"
      echo "  --desc DESCRIPTION          One-line project description"
      echo "  --arch PATTERN              Architecture: monolith|monorepo|microservices|serverless|library"
      echo "  --backend-framework NAME    Backend framework (e.g., fastapi, express, gin)"
      echo "  --frontend-framework NAME   Frontend framework (e.g., react, vue, svelte)"
      echo "  --data-tools TOOLS          Data tools (e.g., pandas, sqlalchemy, spark)"
      echo "  --database DB               Database: postgres|mysql|sqlite|mongodb|none"
      echo "  --full                      Scaffold full docs/ knowledge base (design-docs, exec-plans, etc.)"
      echo "  --gitignore                 Add BMAD files to .gitignore (for existing/corporate repos)"
      echo "  --no-gitignore              Commit BMAD files to repo (for new projects, default)"
      echo "  --non-interactive           Use defaults, no prompts"
      exit 0
      ;;
    *) warn "Unknown option: $1"; shift ;;
  esac
done

# ─── Interactive prompts ───────────────────────────────────────────────────────
DEFAULT_NAME="$(basename "${REPO_ROOT}")"

if [[ -z "${PROJECT_NAME}" ]] && [[ "${NON_INTERACTIVE}" == false ]]; then
  prompt "Project name? [${DEFAULT_NAME}]"
  read -r input
  PROJECT_NAME="${input:-${DEFAULT_NAME}}"
fi
PROJECT_NAME="${PROJECT_NAME:-${DEFAULT_NAME}}"

if [[ -z "${DESCRIPTION}" ]] && [[ "${NON_INTERACTIVE}" == false ]]; then
  prompt "One-line project description?"
  read -r DESCRIPTION
fi
DESCRIPTION="${DESCRIPTION:-A software project using BMAD story-driven development.}"

if [[ -z "${PRIMARY_STACK}" ]] && [[ "${NON_INTERACTIVE}" == false ]]; then
  echo ""
  echo "  1) python"
  echo "  2) typescript"
  echo "  3) go"
  echo "  4) other"
  prompt "Primary language? [1]"
  read -r stack_choice
  case "${stack_choice}" in
    2) PRIMARY_STACK="typescript" ;;
    3) PRIMARY_STACK="go" ;;
    4) PRIMARY_STACK="other" ;;
    *) PRIMARY_STACK="python" ;;
  esac
fi
PRIMARY_STACK="${PRIMARY_STACK:-python}"

if [[ -z "${SPECIALISTS_RAW}" ]] && [[ "${NON_INTERACTIVE}" == false ]]; then
  echo ""
  echo "  Available specialists: backend, frontend, data, qa, infra"
  prompt "Which specialists? (comma-separated) [backend,qa]"
  read -r SPECIALISTS_RAW
fi
SPECIALISTS_RAW="${SPECIALISTS_RAW:-backend,qa}"

# ─── Architecture pattern ────────────────────────────────────────────────────
if [[ -z "${ARCH_PATTERN}" ]] && [[ "${NON_INTERACTIVE}" == false ]]; then
  echo ""
  echo "  1) monolith"
  echo "  2) monorepo"
  echo "  3) microservices"
  echo "  4) serverless"
  echo "  5) library/package"
  prompt "Architecture pattern? [1]"
  read -r arch_choice
  case "${arch_choice}" in
    2) ARCH_PATTERN="monorepo" ;;
    3) ARCH_PATTERN="microservices" ;;
    4) ARCH_PATTERN="serverless" ;;
    5) ARCH_PATTERN="library" ;;
    *) ARCH_PATTERN="monolith" ;;
  esac
fi
ARCH_PATTERN="${ARCH_PATTERN:-monolith}"

# ─── Database ────────────────────────────────────────────────────────────────
if [[ -z "${DATABASE}" ]] && [[ "${NON_INTERACTIVE}" == false ]]; then
  echo ""
  echo "  1) postgres"
  echo "  2) mysql"
  echo "  3) sqlite"
  echo "  4) mongodb"
  echo "  5) none"
  prompt "Database? [5]"
  read -r db_choice
  case "${db_choice}" in
    1) DATABASE="postgres" ;;
    2) DATABASE="mysql" ;;
    3) DATABASE="sqlite" ;;
    4) DATABASE="mongodb" ;;
    *) DATABASE="none" ;;
  esac
fi
DATABASE="${DATABASE:-none}"

# ─── Stack defaults ────────────────────────────────────────────────────────────
case "${PRIMARY_STACK}" in
  python)
    TEST_CMD="pytest"
    LINT_CMD="ruff check ."
    FORMAT_CHECK_CMD="ruff format --check ."
    FORMAT_FIX_CMD="ruff check --fix ."
    ENV_ACTIVATE_CMD="source venv/bin/activate"
    DEPS_INSTALL_CMD="pip install -r requirements.txt"
    APP_LAUNCH_CMD="python main.py  # or: streamlit run app.py / uvicorn app:app"
    SETUP_CMDS="python -m venv venv\nsource venv/bin/activate\npip install -r requirements.txt"
    ;;
  typescript)
    TEST_CMD="npm test"
    LINT_CMD="eslint ."
    FORMAT_CHECK_CMD="prettier --check ."
    FORMAT_FIX_CMD="prettier --write ."
    ENV_ACTIVATE_CMD="# (no activation needed)"
    DEPS_INSTALL_CMD="npm install"
    APP_LAUNCH_CMD="npm run dev"
    SETUP_CMDS="npm install"
    ;;
  go)
    TEST_CMD="go test ./..."
    LINT_CMD="golangci-lint run"
    FORMAT_CHECK_CMD="gofmt -l ."
    FORMAT_FIX_CMD="gofmt -w ."
    ENV_ACTIVATE_CMD="# (no activation needed)"
    DEPS_INSTALL_CMD="go mod download"
    APP_LAUNCH_CMD="go run main.go"
    SETUP_CMDS="go mod download"
    ;;
  *)
    TEST_CMD="make test"
    LINT_CMD="make lint"
    FORMAT_CHECK_CMD="make format-check"
    FORMAT_FIX_CMD="make format"
    ENV_ACTIVATE_CMD="# configure for your stack"
    DEPS_INSTALL_CMD="# install dependencies"
    APP_LAUNCH_CMD="# launch command"
    SETUP_CMDS="# setup steps"
    ;;
esac

# ─── Parse specialists ─────────────────────────────────────────────────────────
IFS=',' read -ra SPECIALIST_LIST <<< "${SPECIALISTS_RAW}"
SPECIALIST_LIST=("${SPECIALIST_LIST[@]// /}")  # trim spaces

# ─── Framework-specific prompts (conditional on specialists) ─────────────────
if [[ "${NON_INTERACTIVE}" == false ]]; then
  for spec in "${SPECIALIST_LIST[@]}"; do
    case "${spec}" in
      backend)
        if [[ -z "${BACKEND_FRAMEWORK}" ]]; then
          echo ""
          prompt "Backend framework? (e.g., fastapi, django, express, gin) [${PRIMARY_STACK} default]"
          read -r BACKEND_FRAMEWORK
        fi
        ;;
      frontend)
        if [[ -z "${FRONTEND_FRAMEWORK}" ]]; then
          echo ""
          prompt "Frontend framework? (e.g., react, vue, angular, svelte, nextjs) []"
          read -r FRONTEND_FRAMEWORK
        fi
        ;;
      data)
        if [[ -z "${DATA_TOOLS}" ]]; then
          echo ""
          prompt "Data tools? (e.g., pandas, sqlalchemy, spark, dbt) []"
          read -r DATA_TOOLS
        fi
        ;;
    esac
  done
fi

# Set defaults based on stack if not provided
if [[ -z "${BACKEND_FRAMEWORK}" ]]; then
  case "${PRIMARY_STACK}" in
    python)     BACKEND_FRAMEWORK="Python" ;;
    typescript) BACKEND_FRAMEWORK="TypeScript" ;;
    go)         BACKEND_FRAMEWORK="Go" ;;
    *)          BACKEND_FRAMEWORK="${PRIMARY_STACK}" ;;
  esac
fi
FRONTEND_FRAMEWORK="${FRONTEND_FRAMEWORK:-}"
DATA_TOOLS="${DATA_TOOLS:-}"

# ─── Auto-detect key directories ─────────────────────────────────────────────
DETECTED_DIRS=""
for dir in src server web lib app api cmd pkg internal tests test spec public; do
  [[ -d "${dir}" ]] && DETECTED_DIRS="${DETECTED_DIRS} ${dir}/"
done

if [[ -n "${DETECTED_DIRS}" ]] && [[ "${NON_INTERACTIVE}" == false ]]; then
  info "Detected directories:${DETECTED_DIRS}"
  prompt "Include in key files? [Y/n]"
  read -r confirm
  [[ "${confirm}" =~ ^[Nn]$ ]] && DETECTED_DIRS=""
fi

# ─── Portable capitalize helper ───────────────────────────────────────────────
capitalize() { echo "$1" | awk '{print toupper(substr($0,1,1)) substr($0,2)}'; }

# ─── Build architecture summary ──────────────────────────────────────────────
ARCH_CAP="$(capitalize "${ARCH_PATTERN}")"
ARCH_DESC="${ARCH_CAP} ${PRIMARY_STACK} application"
[[ "${BACKEND_FRAMEWORK}" != "${PRIMARY_STACK}" ]] && [[ "${BACKEND_FRAMEWORK}" != "Python" ]] && [[ "${BACKEND_FRAMEWORK}" != "TypeScript" ]] && [[ "${BACKEND_FRAMEWORK}" != "Go" ]] && ARCH_DESC="${ARCH_CAP} ${BACKEND_FRAMEWORK} application"
[[ "${DATABASE}" != "none" ]] && ARCH_DESC="${ARCH_DESC} with ${DATABASE}"
ARCH_DESC="${ARCH_DESC}."

# Build tech stack table rows
TECH_STACK_ROWS="| Language | ${PRIMARY_STACK} |"
[[ -n "${BACKEND_FRAMEWORK}" ]] && TECH_STACK_ROWS="${TECH_STACK_ROWS}\n| Backend  | ${BACKEND_FRAMEWORK} |"
[[ -n "${FRONTEND_FRAMEWORK}" ]] && TECH_STACK_ROWS="${TECH_STACK_ROWS}\n| Frontend | ${FRONTEND_FRAMEWORK} |"
[[ "${DATABASE}" != "none" ]] && TECH_STACK_ROWS="${TECH_STACK_ROWS}\n| Database | ${DATABASE} |"
[[ -n "${DATA_TOOLS}" ]] && TECH_STACK_ROWS="${TECH_STACK_ROWS}\n| Data     | ${DATA_TOOLS} |"

# Build key files table rows from detected dirs
KEY_FILES_ROWS=""
_kf_sep=""
for dir in ${DETECTED_DIRS}; do
  case "${dir}" in
    src/)      KEY_FILES_ROWS="${KEY_FILES_ROWS}${_kf_sep}| Source Code | \`${dir}\` |" ;;
    server/)   KEY_FILES_ROWS="${KEY_FILES_ROWS}${_kf_sep}| Server | \`${dir}\` |" ;;
    web/)      KEY_FILES_ROWS="${KEY_FILES_ROWS}${_kf_sep}| Web Frontend | \`${dir}\` |" ;;
    lib/)      KEY_FILES_ROWS="${KEY_FILES_ROWS}${_kf_sep}| Library | \`${dir}\` |" ;;
    app/)      KEY_FILES_ROWS="${KEY_FILES_ROWS}${_kf_sep}| Application | \`${dir}\` |" ;;
    api/)      KEY_FILES_ROWS="${KEY_FILES_ROWS}${_kf_sep}| API | \`${dir}\` |" ;;
    cmd/)      KEY_FILES_ROWS="${KEY_FILES_ROWS}${_kf_sep}| CLI/Commands | \`${dir}\` |" ;;
    tests/|test/|spec/) KEY_FILES_ROWS="${KEY_FILES_ROWS}${_kf_sep}| Tests | \`${dir}\` |" ;;
    public/)   KEY_FILES_ROWS="${KEY_FILES_ROWS}${_kf_sep}| Static Assets | \`${dir}\` |" ;;
    *)         KEY_FILES_ROWS="${KEY_FILES_ROWS}${_kf_sep}| ${dir%/} | \`${dir}\` |" ;;
  esac
  _kf_sep="\n"
done

# ─── Create directory structure ────────────────────────────────────────────────
info "Creating BMAD directory structure..."
mkdir -p bmad/qf-bmad/workflows
mkdir -p bmad/qf-bmad/tasks
mkdir -p bmad/qf-bmad/templates
mkdir -p bmad/qf-bmad/checklists
mkdir -p bmad/qf-bmad/agents/active
mkdir -p bmad/epics

# ─── Copy template files ────────────────────────────────────────────────────────
info "Copying workflow, task, template, and checklist files..."
cp "${TEMPLATE_DIR}/workflows/"*.md bmad/qf-bmad/workflows/
cp "${TEMPLATE_DIR}/tasks/"*.md bmad/qf-bmad/tasks/
cp "${TEMPLATE_DIR}/templates/"* bmad/qf-bmad/templates/
cp "${TEMPLATE_DIR}/checklists/"*.md bmad/qf-bmad/checklists/

# Replace placeholders in checklist files
for f in bmad/qf-bmad/checklists/*.md; do
  sed -i.bak \
    -e "s|{{ENV_ACTIVATE_CMD}}|${ENV_ACTIVATE_CMD}|g" \
    -e "s|{{DEPS_INSTALL_CMD}}|${DEPS_INSTALL_CMD}|g" \
    -e "s|{{APP_LAUNCH_CMD}}|${APP_LAUNCH_CMD}|g" \
    -e "s|{{TEST_CMD}}|${TEST_CMD}|g" \
    -e "s|{{LINT_CMD}}|${LINT_CMD}|g" \
    -e "s|{{FORMAT_CMD}}|${FORMAT_CHECK_CMD}|g" \
    "${f}" && rm "${f}.bak"
done

# ─── Copy ARCHITECTURE.md to repo root ─────────────────────────────────────────
if [[ ! -f "ARCHITECTURE.md" ]]; then
  if [[ -f "${TEMPLATE_DIR}/templates/architecture-template.md" ]]; then
    info "Creating ARCHITECTURE.md..."
    cp "${TEMPLATE_DIR}/templates/architecture-template.md" ARCHITECTURE.md
    sed -i.bak \
      -e "s|{{PROJECT_NAME}}|${PROJECT_NAME}|g" \
      -e "s|{{PROJECT_DESCRIPTION}}|${DESCRIPTION}|g" \
      ARCHITECTURE.md && rm ARCHITECTURE.md.bak
    success "ARCHITECTURE.md created at repo root. Customize it for your project."
  fi
else
  warn "ARCHITECTURE.md already exists — skipping."
fi

# ─── Copy golden-principles.md to bmad/qf-bmad/ ──────────────────────────────
if [[ -f "${TEMPLATE_DIR}/templates/golden-principles.md" ]]; then
  info "Creating golden-principles.md..."
  cp "${TEMPLATE_DIR}/templates/golden-principles.md" bmad/qf-bmad/golden-principles.md
  sed -i.bak \
    -e "s|{{PROJECT_NAME}}|${PROJECT_NAME}|g" \
    bmad/qf-bmad/golden-principles.md && rm bmad/qf-bmad/golden-principles.md.bak
  success "bmad/qf-bmad/golden-principles.md created."
fi

# Replace placeholders in task files
for f in bmad/qf-bmad/tasks/*.md; do
  sed -i.bak \
    -e "s|{{TEST_COMMAND}}|${TEST_CMD}|g" \
    -e "s|{{LINT_COMMAND}}|${LINT_CMD}|g" \
    -e "s|{{APP_LAUNCH_COMMAND}}|${APP_LAUNCH_CMD}|g" \
    "${f}" && rm "${f}.bak"
done

# Replace placeholders in workflow files
for f in bmad/qf-bmad/workflows/*.md; do
  sed -i.bak \
    -e "s|{{PROJECT_NAME}}|${PROJECT_NAME}|g" \
    -e "s|{{TEST_COMMAND}}|${TEST_CMD}|g" \
    -e "s|{{LINT_COMMAND}}|${LINT_CMD}|g" \
    -e "s|{{APP_LAUNCH_COMMAND}}|${APP_LAUNCH_CMD}|g" \
    "${f}" && rm "${f}.bak"
done

# Replace specialist table in bmad-flow.md with actual specialist list
if [[ -f "bmad/qf-bmad/workflows/bmad-flow.md" ]]; then
  FLOW_TABLE_TMP=$(mktemp)
  for spec in "${SPECIALIST_LIST[@]}"; do
    spec_cap="$(capitalize "${spec}")"
    echo "| **${spec_cap} Specialist** | ${spec_cap} domain expertise |" >> "${FLOW_TABLE_TMP}"
  done

  awk -v table_file="${FLOW_TABLE_TMP}" '
    /<!-- TODO:.*Replace with your active specialists/ {
      while ((getline line < table_file) > 0) print line
      close(table_file)
      # Consume rest of multi-line HTML comment
      if ($0 !~ /-->/) { while (getline > 0 && $0 !~ /-->/) {} }
      next
    }
    { print }
  ' "bmad/qf-bmad/workflows/bmad-flow.md" > "bmad/qf-bmad/workflows/bmad-flow.md.tmp" && \
    mv "bmad/qf-bmad/workflows/bmad-flow.md.tmp" "bmad/qf-bmad/workflows/bmad-flow.md"

  rm -f "${FLOW_TABLE_TMP}"
fi

# ─── Derive test framework name ─────────────────────────────────────────────
TEST_FRAMEWORK="${TEST_CMD%% *}"

# ─── Copy and customize specialist agents ──────────────────────────────────────
info "Setting up specialist agents: ${SPECIALISTS_RAW}..."
for spec in "${SPECIALIST_LIST[@]}"; do
  stub_file="${TEMPLATE_DIR}/agents/stubs/${spec}-specialist.md"
  if [[ -f "${stub_file}" ]]; then
    dest="bmad/qf-bmad/agents/active/${spec}-specialist.md"
    if [[ -f "${dest}" ]]; then
      warn "  Skipping ${spec}-specialist.md (already exists, preserving customizations)"
    else
      cp "${stub_file}" "${dest}"
      # Replace project name, test framework, and specialist-specific placeholders
      SPEC_TECH="" SPEC_FOCUS="" SPEC_FILES=""
      case "${spec}" in
        backend)
          SPEC_TECH="${BACKEND_FRAMEWORK}"
          SPEC_FOCUS="${PROJECT_NAME} backend services"
          SPEC_FILES="$(echo "${DETECTED_DIRS}" | tr ' ' '\n' | grep -E '^(src|server|app|api|lib|cmd)/' | tr '\n' ', ' | sed 's/,$//' || true)"
          ;;
        frontend)
          SPEC_TECH="${FRONTEND_FRAMEWORK:-${PRIMARY_STACK}}"
          SPEC_FOCUS="${PROJECT_NAME} frontend UI"
          SPEC_FILES="$(echo "${DETECTED_DIRS}" | tr ' ' '\n' | grep -E '^(web|public|src|app)/' | tr '\n' ', ' | sed 's/,$//' || true)"
          ;;
        data)
          SPEC_TECH="${DATA_TOOLS:-${PRIMARY_STACK}}"
          SPEC_FOCUS="${PROJECT_NAME} data pipelines and storage"
          SPEC_FILES="$(echo "${DETECTED_DIRS}" | tr ' ' '\n' | grep -E '^(data|src|lib)/' | tr '\n' ', ' | sed 's/,$//' || true)"
          ;;
        infra)
          SPEC_TECH="Infrastructure"
          SPEC_FOCUS="${PROJECT_NAME} deployment and operations"
          SPEC_FILES="Dockerfile, docker-compose.yml, terraform/, .github/workflows/"
          ;;
      esac

      sed -i.bak \
        -e "s|{{PROJECT_NAME}}|${PROJECT_NAME}|g" \
        -e "s|{{TEST_FRAMEWORK}}|${TEST_FRAMEWORK}|g" \
        "${dest}" && rm "${dest}.bak"

      # Replace specialist-specific TODO markers if we have values
      if [[ -n "${SPEC_TECH}" ]]; then
        UPPER_SPEC="$(echo "${spec}" | tr '[:lower:]' '[:upper:]')"
        sed -i.bak \
          -e "s|<!-- TODO: e.g.,.* --> implementation patterns|${SPEC_TECH} implementation patterns|g" \
          -e "s|<!-- TODO: e.g.,.* --> components and state|${SPEC_TECH} components and state|g" \
          -e "s|<!-- TODO: e.g.,.* --> data processing|${SPEC_TECH} data processing|g" \
          -e "s|<!-- TODO: e.g.,.* --> deployment and configuration|${SPEC_TECH} deployment and configuration|g" \
          "${dest}" && rm "${dest}.bak"
      fi
      if [[ -n "${SPEC_FOCUS}" ]]; then
        sed -i.bak \
          -e "s|<!-- TODO: e.g.,.* domain expertise -->|${SPEC_FOCUS}|g" \
          -e "s|<!-- TODO: e.g.,.* API services.*-->|${SPEC_FOCUS}|g" \
          -e "s|<!-- TODO: e.g.,.* UI components.*-->|${SPEC_FOCUS}|g" \
          -e "s|<!-- TODO: e.g.,.* Data pipelines.*-->|${SPEC_FOCUS}|g" \
          -e "s|<!-- TODO: e.g.,.* Deployment.*-->|${SPEC_FOCUS}|g" \
          "${dest}" && rm "${dest}.bak"
      fi
      if [[ -n "${SPEC_FILES}" ]]; then
        sed -i.bak \
          -e "s|<!-- TODO: e.g.,.* app/api/.*-->|${SPEC_FILES}|g" \
          -e "s|<!-- TODO: e.g.,.* src/components/.*-->|${SPEC_FILES}|g" \
          -e "s|<!-- TODO: e.g.,.* app/data/.*-->|${SPEC_FILES}|g" \
          -e "s|<!-- TODO: e.g.,.* Dockerfile.*-->|${SPEC_FILES}|g" \
          "${dest}" && rm "${dest}.bak"
      fi

      success "  Created ${dest}"
    fi
  else
    warn "  No stub found for '${spec}' — creating blank agent file"
    SPEC_CAP="$(capitalize "${spec}")"
    cat > "bmad/qf-bmad/agents/active/${spec}-specialist.md" << EOF
# ${SPEC_CAP} Specialist - ${PROJECT_NAME}

ACTIVATION-NOTICE: Load this persona when working on ${spec} concerns.

**Domain**: ${spec}
**Project**: ${PROJECT_NAME}

## Expertise
- [Define ${spec} focus areas]

## Quality Gates
- [ ] [Define ${spec}-specific quality criteria]
EOF
  fi
done

# ─── Create BMAD Master ────────────────────────────────────────────────────────
if [[ ! -f "bmad/qf-bmad/agents/bmad-master.md" ]]; then
  info "Creating BMAD Master agent..."
  cp "${TEMPLATE_DIR}/agents/bmad-master.md" bmad/qf-bmad/agents/bmad-master.md

  sed -i.bak \
    -e "s|{{PROJECT_NAME}}|${PROJECT_NAME}|g" \
    -e "s|{{PROJECT_DESCRIPTION}}|${DESCRIPTION}|g" \
    -e "s|{{PROJECT_DOMAIN}}|${PROJECT_NAME}|g" \
    "bmad/qf-bmad/agents/bmad-master.md" && rm "bmad/qf-bmad/agents/bmad-master.md.bak"

  # Build specialist content files for awk-based replacement
  SPEC_LIST_TMP=$(mktemp)
  SPEC_TABLE_TMP=$(mktemp)

  for spec in "${SPECIALIST_LIST[@]}"; do
    echo "    - ${spec}-specialist.md" >> "${SPEC_LIST_TMP}"
  done

  {
    echo "| Agent | Focus Area |"
    echo "|-------|------------|"
    for spec in "${SPECIALIST_LIST[@]}"; do
      spec_cap="$(capitalize "${spec}")"
      echo "| **${spec_cap} Specialist** | ${spec_cap} domain expertise |"
    done
  } > "${SPEC_TABLE_TMP}"

  # Replace {{SPECIALIST_AGENTS_LIST}} and {{SPECIALIST_AGENTS_TABLE}} using awk
  awk -v list_file="${SPEC_LIST_TMP}" -v table_file="${SPEC_TABLE_TMP}" '
    /\{\{SPECIALIST_AGENTS_LIST\}\}/ {
      while ((getline line < list_file) > 0) print line
      close(list_file)
      next
    }
    /\{\{SPECIALIST_AGENTS_TABLE\}\}/ {
      while ((getline line < table_file) > 0) print line
      close(table_file)
      next
    }
    { print }
  ' "bmad/qf-bmad/agents/bmad-master.md" > "bmad/qf-bmad/agents/bmad-master.md.tmp" && \
    mv "bmad/qf-bmad/agents/bmad-master.md.tmp" "bmad/qf-bmad/agents/bmad-master.md"

  rm -f "${SPEC_LIST_TMP}" "${SPEC_TABLE_TMP}"

  # Append specialist reference list to BMAD master
  {
    echo ""
    echo "### Active Specialists"
    for spec in "${SPECIALIST_LIST[@]}"; do
      echo "- $(capitalize "${spec}") Specialist: see \`bmad/qf-bmad/agents/active/${spec}-specialist.md\`"
    done
  } >> bmad/qf-bmad/agents/bmad-master.md
fi

# ─── Create core-config.yaml ────────────────────────────────────────────────────
info "Creating core-config.yaml..."

cp "${TEMPLATE_DIR}/core-config.yaml.template" bmad/qf-bmad/core-config.yaml
sed -i.bak \
  -e "s|{{PROJECT_NAME}}|${PROJECT_NAME}|g" \
  -e "s|{{PROJECT_DESCRIPTION}}|${DESCRIPTION}|g" \
  -e "s|{{PRIMARY_LANGUAGE}}|${PRIMARY_STACK}|g" \
  -e "s|{{TEST_COMMAND}}|${TEST_CMD}|g" \
  -e "s|{{LINT_COMMAND}}|${LINT_CMD}|g" \
  -e "s|{{FORMAT_CHECK_COMMAND}}|${FORMAT_CHECK_CMD}|g" \
  -e "s|{{APP_LAUNCH_COMMAND}}|${APP_LAUNCH_CMD}|g" \
  -e "s|{{ENV_ACTIVATE_CMD}}|${ENV_ACTIVATE_CMD}|g" \
  bmad/qf-bmad/core-config.yaml && rm bmad/qf-bmad/core-config.yaml.bak
# Append specialists section to core-config
echo "" >> bmad/qf-bmad/core-config.yaml
echo "specialists:" >> bmad/qf-bmad/core-config.yaml
for spec in "${SPECIALIST_LIST[@]}"; do
  echo "  - ${spec}" >> bmad/qf-bmad/core-config.yaml
done

# ─── Full docs/ scaffold (--full flag) ─────────────────────────────────────────
if [[ "${FULL_SCAFFOLD}" == true ]]; then
  info "Scaffolding full docs/ knowledge base..."
  mkdir -p docs/design-docs docs/exec-plans/active docs/exec-plans/completed \
           docs/product-specs docs/references docs/generated

  # Copy and customize template files
  _docs_templates=(
    "docs/design-docs/core-beliefs.md"
    "docs/design-docs/index.md"
    "docs/product-specs/index.md"
    "docs/references/README.md"
    "docs/exec-plans/tech-debt-tracker.md"
    "docs/QUALITY_SCORE.md"
  )
  for _tpl in "${_docs_templates[@]}"; do
    if [[ -f "${TEMPLATE_DIR}/${_tpl}" ]]; then
      cp "${TEMPLATE_DIR}/${_tpl}" "${_tpl}"
      sed -i.bak -e "s|{{PROJECT_NAME}}|${PROJECT_NAME}|g" "${_tpl}" && rm "${_tpl}.bak"
    fi
  done

  # Ensure generated/ dir is tracked even when empty
  if [[ -f "${TEMPLATE_DIR}/docs/generated/.gitkeep" ]]; then
    cp "${TEMPLATE_DIR}/docs/generated/.gitkeep" docs/generated/.gitkeep
  else
    touch docs/generated/.gitkeep
  fi

  success "docs/ directory scaffolded: design-docs, exec-plans, product-specs, references, generated"
fi

# ─── Generate CLAUDE.md ────────────────────────────────────────────────────────
if [[ -f "CLAUDE.md" ]]; then
  warn "CLAUDE.md already exists — skipping generation. Edit manually or delete and re-run."
else
  info "Generating CLAUDE.md..."
  cp "${TEMPLATE_DIR}/CLAUDE.md.template" CLAUDE.md
  sed -i.bak \
    -e "s|{{PROJECT_NAME}}|${PROJECT_NAME}|g" \
    -e "s|{{PROJECT_DESCRIPTION}}|${DESCRIPTION}|g" \
    -e "s|{{TEST_COMMAND}}|${TEST_CMD}|g" \
    -e "s|{{TEST_FRAMEWORK}}|${TEST_CMD%% *}|g" \
    -e "s|{{LINT_COMMAND}}|${LINT_CMD}|g" \
    -e "s|{{FORMAT_CHECK_COMMAND}}|${FORMAT_CHECK_CMD}|g" \
    -e "s|{{APP_LAUNCH_COMMAND}}|${APP_LAUNCH_CMD}|g" \
    -e "s|{{SETUP_COMMANDS}}|${SETUP_CMDS}|g" \
    -e "s|{{ARCHITECTURE_SUMMARY}}|${ARCH_DESC}|g" \
    CLAUDE.md && rm CLAUDE.md.bak

  # Replace multi-line placeholders using Python for cross-platform reliability
  python3 -c "
import sys
content = open('CLAUDE.md').read()
tech = '''$(printf '%b' "${TECH_STACK_ROWS}")'''
keys = '''$(printf '%b' "${KEY_FILES_ROWS}")'''
content = content.replace('{{TECH_STACK_TABLE}}', tech)
if keys.strip():
    content = content.replace('{{KEY_FILES_TABLE}}', keys)
open('CLAUDE.md', 'w').write(content)
"

  success "CLAUDE.md created with detected settings. Review and customize as needed."
fi

# ─── Gitignore prompt ─────────────────────────────────────────────────────────
if [[ -z "${GITIGNORE_BMAD}" ]] && [[ "${NON_INTERACTIVE}" == false ]]; then
  echo ""
  prompt "Add BMAD files to .gitignore? (recommended for existing/corporate repos) [y/N]"
  read -r gi_confirm
  [[ "${gi_confirm}" =~ ^[Yy]$ ]] && GITIGNORE_BMAD="yes" || GITIGNORE_BMAD="no"
fi
GITIGNORE_BMAD="${GITIGNORE_BMAD:-no}"

# ─── Update .gitignore ────────────────────────────────────────────────────────
if [[ "${GITIGNORE_BMAD}" == "yes" ]]; then
  # Ensure .gitignore exists
  touch .gitignore

  if ! grep -q '^CLAUDE\.md$' .gitignore 2>/dev/null; then
    {
      echo ""
      echo "# BMAD framework (local dev tooling)"
      echo "CLAUDE.md"
      echo "bmad/"
    } >> .gitignore
    success "Added CLAUDE.md and bmad/ to .gitignore"
  fi
else
  # Even when committing BMAD files, ignore draft stories
  if [[ -f ".gitignore" ]]; then
    if ! grep -q "bmad/epics/\*/stories/\.draft/" .gitignore 2>/dev/null; then
      {
        echo ""
        echo "# BMAD draft stories"
        echo "bmad/epics/*/stories/.draft/"
      } >> .gitignore
      info "Updated .gitignore"
    fi
  fi
fi

# ─── Catchall: convert remaining {{PLACEHOLDERS}} to TODO markers ─────────────
info "Checking for remaining placeholders..."
REMAINING=0
for f in CLAUDE.md bmad/qf-bmad/agents/*.md bmad/qf-bmad/agents/active/*.md bmad/qf-bmad/workflows/*.md bmad/qf-bmad/tasks/*.md bmad/qf-bmad/checklists/*.md bmad/qf-bmad/*.yaml; do
  if [[ -f "${f}" ]] && grep -qE '\{\{[A-Z0-9_]+\}\}' "${f}" 2>/dev/null; then
    sed -i.bak -E 's/\{\{([A-Z0-9_]+)\}\}/<!-- TODO: Fill in \1. Run \/configure to auto-detect. -->/g' "${f}" && rm -f "${f}.bak"
    count=$(grep -c 'TODO: Fill in' "${f}" 2>/dev/null || true)
    REMAINING=$((REMAINING + count))
  fi
done

if [[ ${REMAINING} -gt 0 ]]; then
  warn "${REMAINING} TODO markers remaining — /configure can auto-fill most of them"
else
  success "All placeholders filled!"
fi

