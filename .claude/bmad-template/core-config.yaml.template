project:
  name: "{{PROJECT_NAME}}"
  description: "{{PROJECT_DESCRIPTION}}"
  language: "{{PRIMARY_LANGUAGE}}"
  version: "1.0.0"

bmad:
  version: "1.0.0"
  epic_dir: "bmad/epics"
  workflow_dir: "bmad/config/workflows"
  agent_dir: "bmad/config/agents/active"

commands:
  test: "{{TEST_COMMAND}}"
  lint: "{{LINT_COMMAND}}"
  format_check: "{{FORMAT_CHECK_COMMAND}}"
  app_launch: "{{APP_LAUNCH_COMMAND}}"
  env_activate: "{{ENV_ACTIVATE_CMD}}"

structural_validation:
  enabled: false  # Set true when validation scripts exist
  checks:
    # Uncomment and configure checks for your project:
    # - name: "Dependency Direction"
    #   command: "python lints/check_dependencies.py"
    # - name: "File Size Limits"
    #   command: "python lints/check_file_sizes.py --max 300"
    # - name: "Naming Conventions"
    #   command: "python lints/check_naming.py"
    # - name: "Boundary Validation"
    #   command: "python lints/check_boundaries.py"

quality_gates:
  pre_work:
    - env_active
    - app_launches
    - tests_pass
    - lint_clean
  post_work:
    - tests_pass
    - lint_clean
    - format_clean
    - app_launches
    - story_updated
